        pdrain | pixeldrain) printf '%s' "960" ;;
        mp4upload) printf '%s' "930" ;;
        upnshare) printf '%s' "920" ;;
        terabox) printf '%s' "910" ;;
        1fichier) printf '%s' "900" ;;
        *) printf '%s' "880" ;;
