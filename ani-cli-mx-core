# ponytail: id interno de animeflv (para thumbnails por episodio) — best effort,
# timeout corto porque el sitio esta de capa caida
animeflv_internal_id() {
    curl -s -L --connect-timeout 3 --max-time 6 -e "$allanime_refr" -A "$agent" \
        "${allanime_refr}/anime/$1" |
        sed -nE 's/.*anime_info = \["([0-9]+)".*/\1/p' | head -n1
}

# ponytail: baja el thumbnail de UN episodio probando fuentes en orden:
# 1) jkanime og:image de la pagina del ep · 2) animeflv screenshots (de capa caida)
# $1 = ep · $2 = aid animeflv (puede ser vacio) · $3 = slug limpio · $4 = outfile
fetch_ep_thumb() {
    local ep="$1" aid="$2" slug="$3" out="$4" u
    u=$(curl -s -L --connect-timeout 5 --max-time 10 -A "$agent" \
        "${jkanime_refr}/${slug}/${ep}/" |
        sed -n 's/.*og:image" content="\([^"]*\)".*/\1/p' | head -n1)
    [ -n "$u" ] && curl -s -f --connect-timeout 5 --max-time 10 -o "$out" "$u" && return 0
    if [ -n "$aid" ]; then
        curl -s -f --connect-timeout 5 --max-time 10 -o "$out" \
            "https://cdn.animeflv.net/screenshots/$aid/$ep/th_3.jpg" && return 0
    fi
    return 1
}

# ponytail: selector de episodios con grid de tarjetas — thumbnail real por capitulo,
# multi-fuente (animeflv → jkanime) · fallback: portada del anime
# $1 = id/slug del anime (acepta prefijos animeav1:/jkanime:) · $2 = portada fallback · stdin = ep_list
select_episode_grid() {
    local raw_id="$1" cover_img="$2"
    local slug eps aid ep_cache data_file ep img result last_ep pids_file
    slug="${raw_id#animeav1:}"; slug="${slug#jkanime:}"; slug="${slug#allanime:}"
    eps=$(cat -)
    [ -z "$eps" ] && return 1
    # latencia: no consultar animeflv (caido) si ya sabemos que la fuente es jkanime
    aid=""
    case "$raw_id" in jkanime:*) ;; *) aid=$(animeflv_internal_id "$slug") ;; esac
    ep_cache="$ani_cache_dir/epthumbs"
    mkdir -p "$ep_cache"
    data_file=$(mktemp) || return 1
    pids_file=$(mktemp)
    for ep in $eps; do
        [ -s "$ep_cache/${slug}_${ep}.jpg" ] && continue   # cache: inmutable por slug+ep
        fetch_ep_thumb "$ep" "$aid" "$slug" "$ep_cache/${slug}_${ep}.jpg" &
        echo $! >> "$pids_file"
    done
    while read -r pid; do wait "$pid" 2>/dev/null; done < "$pids_file"
    rm -f "$pids_file"
    last_ep="$(last_watched_episode_for_current_anime)"
    for ep in $eps; do
        img="$ep_cache/${slug}_${ep}.jpg"
        [ -s "$img" ] || img="$cover_img"
        if [ "$ep" = "$last_ep" ]; then
            printf '%s\tEpisodio %s\t★ último visto\t%s\n' "$img" "$ep" "$ep"
        else
            printf '%s\tEpisodio %s\t\t%s\n' "$img" "$ep" "$ep"
        fi
    done > "$data_file"
    result=$(show_card_grid "$data_file" " episodios")
    local rc=$?
    rm -f "$data_file"
    [ "$rc" -ne 0 ] && return 1
    printf '%s' "$result"
}

# ponytail: fallback fzf para terminales sin kitty graphics
show_browse_grid_fzf() {
