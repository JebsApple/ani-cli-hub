normalize_romanized_text() {
    printf '%s' "$1" | sed '
        s/[Āā]/aa/g
        s/[Ēē]/ei/g
        s/[Īī]/ii/g
        s/[Ōō]/ou/g
        s/[Ūū]/uu/g
        s/[ÂÀÁÄÃÅâàáäãå]/a/g
        s/[ÊÈÉËêèéë]/e/g
        s/[ÎÌÍÏîìíï]/i/g
        s/[ÔÒÓÖÕôòóöõ]/o/g
        s/[ÛÙÚÜûùúü]/u/g
        s/[Çç]/c/g
        s/[Ññ]/n/g
    '
}

normalize_romanized_text_plain() {
    printf '%s' "$1" | sed '
        s/[ĀāÂÀÁÄÃÅâàáäãå]/a/g
        s/[ĒēÊÈÉËêèéë]/e/g
        s/[ĪīÎÌÍÏîìíï]/i/g
        s/[ŌōÔÒÓÖÕôòóöõ]/o/g
        s/[ŪūÛÙÚÜûùúü]/u/g
        s/[Çç]/c/g
        s/[Ññ]/n/g
    '
}

compact_search_query() {
    sed 's|[[:space:]]\+|+|g; s|^+||; s|+$||'
}

search_query_from_text() {
    normalize_romanized_text "$(printf '%s' "$1" | sed 's|+| |g')" |
        compact_search_query
}

search_query_candidates_from_text() {
    query_text="$(printf '%s' "$1" | sed 's|+| |g')"
    {
        normalize_romanized_text "$query_text" | compact_search_query
        normalize_romanized_text_plain "$query_text" | compact_search_query
    } | sed '/^$/d' | awk '!seen[$0]++'
}

normalize_match_key() {
    normalize_romanized_text "$1" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]'
}

normalize_match_words() {
    normalize_romanized_text "$1" | tr '[:upper:]' '[:lower:]' |
        sed 's/[^[:alnum:]]\+/ /g; s/^ *//; s/ *$//; s/[[:space:]][[:space:]]*/ /g'
}

extract_season_hint() {
    normalized_words=" $(normalize_match_words "$1") "
    season_hint="$(printf '%s\n' "$normalized_words" | sed -nE '
        s|.* season ([0-9]+) .*|\1|p
        s|.* ([0-9]+)(st|nd|rd|th) season .*|\1|p
        s|.* temporada ([0-9]+) .*|\1|p
        s|.* ([0-9]+)(a|da|ra) temporada .*|\1|p
        s|.* part ([0-9]+) .*|\1|p
        s|.* cour ([0-9]+) .*|\1|p
        s|.* stage ([0-9]+) .*|\1|p
        s|.* s([0-9]+) .*|\1|p
    ' | head -n1)"
    [ -n "$season_hint" ] && printf '%s\n' "$season_hint" && return 0

    case "$normalized_words" in
        *" first season "* | *" primera temporada "* | *" ichi gakki "*) printf '1\n' ;;
        *" second season "* | *" segunda temporada "* | *" 2nd season "* | *" 2da temporada "* | *" 2a temporada "* | *" ni gakki "*) printf '2\n' ;;
        *" third season "* | *" tercera temporada "* | *" 3rd season "* | *" 3ra temporada "* | *" 3a temporada "* | *" san gakki "*) printf '3\n' ;;
        *" fourth season "* | *" cuarta temporada "* | *" 4th season "* | *" 4ta temporada "* | *" 4a temporada "* | *" yon gakki "*) printf '4\n' ;;
        *" fifth season "* | *" quinta temporada "* | *" 5th season "* | *" 5ta temporada "* | *" 5a temporada "* | *" go gakki "*) printf '5\n' ;;
        *) return 1 ;;
    esac
}

extract_slug_season_hint() {
    raw_slug="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
    printf '%s\n' "$raw_slug" | sed -nE '
        s#.*[-_/]s([0-9]+)$#\1#p
        s#.*[-_/](1st|2nd|3rd|4th|5th)[-_/]season$#\1#p
        s#.*[-_/]season[-_/]?([0-9]+)$#\1#p
        s#.*[-_/]part[-_/]?([0-9]+)$#\1#p
        s#.*[-_/]([1-9])$#\1#p
    ' | sed '
        s/^1st$/1/
        s/^2nd$/2/
        s/^3rd$/3/
        s/^4th$/4/
        s/^5th$/5/
    ' | head -n1
}

match_token_overlap_score() {
    query_words="$(normalize_match_words "$1")"
    candidate_words=" $(normalize_match_words "$2") "
    overlap_score=0
    for word in $query_words; do
        [ "${#word}" -lt 3 ] && continue
        case "$candidate_words" in
            *" $word "*) overlap_score=$((overlap_score + 35)) ;;
        esac
    done
    printf '%s\n' "$overlap_score"
}

match_word_is_generic() {
    case "$1" in
        a | an | and | the | of | no | ni | to | de | del | la | las | el | los | y | en | un | una) return 0 ;;
        season | temporada | movie | pelicula | film | ova | special | specials | episode | episodio) return 0 ;;
        part | cour | stage | first | second | third | fourth | fifth | primera | segunda | tercera | cuarta | quinta) return 0 ;;
        school | gakki | sub | dub) return 0 ;;
        1st | 2nd | 3rd | 4th | 5th | 1ra | 2da | 3ra | 4ta | 5ta | 1a | 2a | 3a | 4a | 5a) return 0 ;;
        *) return 1 ;;
    esac
}

count_distinctive_query_words() {
    query_words="$(normalize_match_words "$1")"
    distinctive_count=0
    for word in $query_words; do
        [ "${#word}" -lt 3 ] && continue
        match_word_is_generic "$word" && continue
        distinctive_count=$((distinctive_count + 1))
    done
    printf '%s\n' "$distinctive_count"
}

count_distinctive_overlap() {
    query_words="$(normalize_match_words "$1")"
    candidate_words=" $(normalize_match_words "$2") "
    distinctive_overlap=0
    for word in $query_words; do
        [ "${#word}" -lt 3 ] && continue
        match_word_is_generic "$word" && continue
        case "$candidate_words" in
            *" $word "*) distinctive_overlap=$((distinctive_overlap + 1)) ;;
        esac
    done
    printf '%s\n' "$distinctive_overlap"
}

title_match_score() {
    query_title="$1"
    candidate_id="$2"
    candidate_title="$3"
    query_key="$(normalize_match_key "$query_title")"
    candidate_key="$(normalize_match_key "$candidate_title")"
    query_context="$(normalize_match_words "$query_title $(printf '%s' "$id" | tr ':|_-' '     ')")"
    candidate_context="$(normalize_match_words "$candidate_title $(printf '%s' "$candidate_id" | tr ':|_-' '     ')")"
    score=0

    [ "$candidate_key" = "$query_key" ] && score=$((score + 1000))
    case "$candidate_key" in
        *"$query_key"*) score=$((score + 400)) ;;
    esac
    case "$query_key" in
        *"$candidate_key"*) score=$((score + 200)) ;;
    esac

    score=$((score + $(match_token_overlap_score "$query_context" "$candidate_context")))
    distinctive_query_count="$(count_distinctive_query_words "$query_context")"
    distinctive_overlap_count="$(count_distinctive_overlap "$query_context" "$candidate_context")"
    if [ "$distinctive_query_count" -gt 0 ]; then
        if [ "$distinctive_overlap_count" -gt 0 ]; then
            score=$((score + (distinctive_overlap_count * 120)))
        else
            score=$((score - 1500))
        fi
    fi

    query_season="$(extract_season_hint "$query_context" 2>/dev/null || true)"
    [ -z "$query_season" ] && query_season="$(extract_slug_season_hint "${id#*:}" 2>/dev/null || true)"
    candidate_season="$(extract_season_hint "$candidate_context" 2>/dev/null || true)"
    [ -z "$candidate_season" ] && candidate_season="$(extract_slug_season_hint "$candidate_id" 2>/dev/null || true)"
    if [ -n "$query_season" ]; then
        if [ "$candidate_season" = "$query_season" ]; then
            score=$((score + 350))
        elif [ -n "$candidate_season" ]; then
            score=$((score - 900))
        else
            score=$((score - 450))
        fi
    elif [ -n "$candidate_season" ]; then
        if [ "$candidate_season" = "1" ]; then
            score=$((score + 60))
        else
            score=$((score - 260))
        fi
    fi

    printf '%s\n' "$score"
}

