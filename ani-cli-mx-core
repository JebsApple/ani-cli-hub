extract_animeav1_links() {
    embeds_blob="$1"
    downloads_blob="$2"
    selected_lang="$3"
    embed_entries="$(extract_animeav1_entries "$embeds_blob" "$selected_lang")"
    download_entries="$(extract_animeav1_entries "$downloads_blob" "$selected_lang")"
    disabled_mirrors="$(disabled_source_mirrors_for_source "animeav1")"
    failed_mirrors=""
    ok_mirrors=""
    primary_links=""
    if fast_first_link_mode; then
        animeav1_entries="${embed_entries}
${download_entries}"
    else
        animeav1_entries="${download_entries}
${embed_entries}"
    fi
    old_ifs=$IFS
    IFS='
'
    for entry in $animeav1_entries; do
        [ -z "$entry" ] && continue
        server_name="$(printf '%s' "$entry" | sed -nE 's|.*server:"([^"]+)".*|\1|p')"
        remote_url="$(printf '%s' "$entry" | sed -nE 's|.*url:"([^"]+)".*|\1|p')"
        [ -z "$server_name" ] && continue
        [ -z "$remote_url" ] && continue
        server_key="$(normalize_mirror_name "$server_name")"
        if source_mirror_is_disabled_in_list "animeav1" "$server_name" "$disabled_mirrors"; then
            source_status "AnimeAV1 ${server_name}" "disabled"
            continue
        fi

        case "$(printf '%s' "$server_name" | tr '[:upper:]' '[:lower:]')" in
            mega)
                continue
                ;;
            hls)
                direct_link="$(extract_animeav1_hls_link "$remote_url")"
                if [ -n "$direct_link" ] && probe_stream_link "$remote_url" "$direct_link"; then
                    if ! printf '%s' "$primary_links" | grep -Fq ">${direct_link}"; then
                        primary_links="${primary_links}$(animeav1_server_priority "$server_name") >${direct_link}
referrer >${direct_link}>${remote_url}
source >${direct_link}>${server_name}
site >${direct_link}>AnimeAV1
"
                    fi
                    [ -n "$server_key" ] && ! printf '%s\n' "$ok_mirrors" | grep -Fxq "$server_key" &&
                        ok_mirrors="${ok_mirrors}${ok_mirrors:+
}${server_key}"
                    source_status "AnimeAV1 ${server_name}" "ok"
                    if fast_first_link_mode; then
                        IFS=$old_ifs
                        printf '%s' "$primary_links"
                        return 0
                    fi
                else
                    [ -n "$server_key" ] && ! printf '%s\n' "$failed_mirrors" | grep -Fxq "$server_key" &&
                        failed_mirrors="${failed_mirrors}${failed_mirrors:+
}${server_key}"
                    source_status "AnimeAV1 ${server_name}" "skip"
                fi
                continue
                ;;
        esac

        direct_link="$(extract_with_ytdlp "$remote_url")"
        if [ -n "$direct_link" ]; then
            if ! printf '%s' "$primary_links" | grep -Fq ">${direct_link}"; then
                primary_links="${primary_links}$(animeav1_server_priority "$server_name") >${direct_link}
source >${direct_link}>${server_name}
site >${direct_link}>AnimeAV1
"
            fi
            [ -n "$server_key" ] && ! printf '%s\n' "$ok_mirrors" | grep -Fxq "$server_key" &&
                ok_mirrors="${ok_mirrors}${ok_mirrors:+
}${server_key}"
            source_status "AnimeAV1 ${server_name}" "ok"
            if fast_first_link_mode; then
                IFS=$old_ifs
                printf '%s' "$primary_links"
                return 0
            fi
        else
            [ -n "$server_key" ] && ! printf '%s\n' "$failed_mirrors" | grep -Fxq "$server_key" &&
                failed_mirrors="${failed_mirrors}${failed_mirrors:+
}${server_key}"
            source_status "AnimeAV1 ${server_name}" "skip"
        fi
    done
    IFS=$old_ifs

    old_ifs=$IFS
    IFS='
'
    for mirror_key in $failed_mirrors; do
        printf '%s\n' "$ok_mirrors" | grep -Fxq "$mirror_key" && continue
        disable_source_mirror "animeav1" "$mirror_key"
    done
    IFS=$old_ifs

    [ -n "$primary_links" ] && printf '%s' "$primary_links"
}

resolve_animeav1_episode() {
    animeav1_match="$(select_animeav1_slug "$1")" || return 1
