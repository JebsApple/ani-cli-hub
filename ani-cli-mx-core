search_animeav1() {
    animeav1_request "${animeav1_refr}/catalogo?search=$1" | tr '\n' ' ' |
        sed 's|<article class="group/item|\n&|g' |
        sed -nE 's|.*<h3[^>]*>([^<]+)</h3>.*href="/media/([^"/?]+)".*|\2\t\1|p'
}

select_animeav1_slug() {
    explicit_slug="$(show_ref_value_for_site "$id" "animeav1")"
    if [ -n "$explicit_slug" ]; then
        animeav1_slug="$explicit_slug"
        animeav1_slug_key="explicit:$id"
    fi
    [ -n "$explicit_slug" ] && printf '%s\n' "$animeav1_slug" && return 0

    cache_key="$1|$id"
    [ "$animeav1_slug_key" = "$cache_key" ] && [ -n "$animeav1_slug" ] && printf '%s\n' "$animeav1_slug" && return 0

    animeav1_results="$(search_animeav1 "$(printf '%s' "$1" | sed 's| |+|g')")"
    [ -z "$animeav1_results" ] && return 1

    best_slug=""
    best_score=-999999
    old_ifs=$IFS
    IFS='
'
    for entry in $animeav1_results; do
        slug="$(printf '%s' "$entry" | cut -f1)"
        name="$(printf '%s' "$entry" | cut -f2)"
        [ -z "$slug" ] && continue
        score="$(title_match_score "$1" "$slug" "$name")"
        [ "$score" -gt "$best_score" ] && best_score="$score" && best_slug="$slug"
    done
    IFS=$old_ifs

    cross_source_match_is_confident "$best_score" || return 1
    [ -z "$best_slug" ] && best_slug="$(printf '%s\n' "$animeav1_results" | sed -n '1p' | cut -f1)"
    [ -z "$best_slug" ] && return 1

    animeav1_slug="$best_slug"
    animeav1_slug_key="$cache_key"
    printf '%s\n' "$animeav1_slug"
}

pick_animeav1_language() {
    case "$mode" in
        dub)
            for lang in LAT ESP DUB SUB; do
                printf '%s' "$1" | grep -q "${lang}:\\[" && printf '%s\n' "$lang" && return 0
            done
            ;;
        *)
            for lang in SUB ESP LAT DUB; do
                printf '%s' "$1" | grep -q "${lang}:\\[" && printf '%s\n' "$lang" && return 0
            done
            ;;
    esac
    return 1
}

