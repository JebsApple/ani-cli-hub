    printf "%s" "iina" && return 0
}

where_mpv() {
    command -v "flatpak" >/dev/null && flatpak info io.mpv.Mpv >/dev/null 2>&1 && printf "%s" "flatpak_mpv" && return 0
    printf "%s" "mpv" && return 0
}

where_wsl_player() {
    windows_player="$1"
    linux_player="$2"

    if command -v "$windows_player" >/dev/null 2>&1 && "$windows_player" --version >/dev/null 2>&1; then
        printf '%s' "$windows_player"
    else
        printf '%s' "$linux_player"
    fi
}

open_browser_url() {
    case "$(uname -a | cut -d " " -f 1,3-)" in
        *Darwin*) command -v open >/dev/null 2>&1 && nohup open "$1" >/dev/null 2>&1 & return 0 ;;
        *ndroid*) command -v termux-open-url >/dev/null 2>&1 && nohup termux-open-url "$1" >/dev/null 2>&1 & return 0 ;;
        *) command -v xdg-open >/dev/null 2>&1 && nohup xdg-open "$1" >/dev/null 2>&1 & return 0 ;;
    esac
    return 1
}

