episodes_list_animeflv() {
    animeflv_request "${allanime_refr}/anime/$*" | tr '\n' ' ' |
        sed -nE 's|.*var episodes = \[(.*)\];.*|\1|p' |
        sed 's|],\[|]\n[|g; s|\[||g; s|\]||g' | cut -d, -f1 | sort -n -k 1
}

episodes_list_animeav1() {
    animeav1_match="$(show_ref_value_for_site "$1" "animeav1")"
    [ -z "$animeav1_match" ] && animeav1_match="$(select_animeav1_slug "$2")"
    [ -z "$animeav1_match" ] && return 1

    animeav1_page="$(animeav1_request "${animeav1_refr}/media/${animeav1_match}")" || return 1
    printf '%s' "$animeav1_page" | tr '\n' ' ' |
        grep -oE 'number:[0-9]+(\.[0-9]+)?' | cut -d: -f2 | awk '!seen[$0]++' | sort -n -k 1
