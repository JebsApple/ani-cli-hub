    local menu preview_cmd result
    menu=$(awk -F'\t' -v dir="$tmpdir" '{ printf "%d\t%s\t%s - Ep %s\t%s/%s.jpg\n", NR, $1, $2, $3, dir, $1 }' "$catalog_file")
    preview_cmd="[ -f {4} ] && $(img_preview_snippet '{4}')"
