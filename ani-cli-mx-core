# ponytail: cache persistente (latencia) — catalogo TTL 6h, thumbs inmutables por slug
ani_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/ani-cli-mx"

# ponytail: catalogo desde jkanime (animeflv de capa caida) — reusa el scraper del
# horario semanal y deduplica slugs. output file: slug\ttitle\tep_no\tthumb_url
# Con cache: catalogo <6h y thumbs ya bajados = arranque casi instantaneo.
fetch_browse_catalog() {
    local catalog_cache="$ani_cache_dir/catalog.tsv" thumbs_dir="$ani_cache_dir/thumbs"
    mkdir -p "$thumbs_dir"
    # cache fresco? (mtime < 6h)
    if [ -s "$catalog_cache" ] && [ -n "$(find "$catalog_cache" -mmin -360 2>/dev/null)" ]; then
        export CATALOG_FILE="$catalog_cache"
        export CATALOG_TMPDIR="$thumbs_dir"
    else
        fetch_weekly_schedule || { # red caida: usar cache viejo si existe
            [ -s "$catalog_cache" ] && export CATALOG_FILE="$catalog_cache" &&
                export CATALOG_TMPDIR="$thumbs_dir" && return 0
            return 1
        }
        [ -s "$SCHEDULE_FILE" ] || return 1
        # schedule: slug\ttitle\tdayslug\tthumb\tepcap → catalogo: slug\ttitle\tep\tthumb
        awk -F'\t' '!seen[$1]++ { printf "%s\t%s\t%s\t%s\n", $1, $2, $5, $4 }' \
            "$SCHEDULE_FILE" > "$catalog_cache"
        rm -f "$SCHEDULE_FILE" 2>/dev/null
        rm -rf "$SCHEDULE_TMPDIR" 2>/dev/null
        export CATALOG_FILE="$catalog_cache"
        export CATALOG_TMPDIR="$thumbs_dir"
    fi
    # bajar solo thumbs faltantes (los presentes son inmutables por slug)
    local slug thumb img_path pids_file
    pids_file=$(mktemp)
    while IFS=$'\t' read -r slug _ _ thumb; do
        img_path="${thumbs_dir}/${slug}.jpg"
        [ -s "$img_path" ] && continue
        curl -s -f -o "$img_path" "$thumb" &
        echo $! >> "$pids_file"
    done < "$CATALOG_FILE"
    while read -r pid; do wait "$pid" 2>/dev/null; done < "$pids_file"
    rm -f "$pids_file"
}

# ── favoritos y watchlist ──────────────────────────────────────────────
# archivos hermanos del histfile, mismo formato tab. id con prefijo de fuente.
ani_fav_has() { [ -f "$hist_dir/ani-favs" ] && grep -q "^$1	" "$hist_dir/ani-favs"; }
ani_fav_toggle() { # $1 id  $2 title
    local f="$hist_dir/ani-favs"
    if ani_fav_has "$1"; then
        grep -v "^$1	" "$f" > "$f.new"; mv "$f.new" "$f"   # grep exit 1 si queda vacio: mv igual
    else
        printf '%s\t%s\n' "$1" "$2" >> "$f"
    fi
}
ani_watch_state() { # $1 id → imprime estado o nada
    [ -f "$hist_dir/ani-watchlist" ] &&
        awk -F'\t' -v id="$1" '$1 == id { print $3; exit }' "$hist_dir/ani-watchlist"
}
ani_watch_cycle() { # $1 id  $2 title — (nada)→pendiente→viendo→completado→(nada)
    local f="$hist_dir/ani-watchlist" cur next
    cur=$(ani_watch_state "$1")
    case "$cur" in
        "") next="pendiente" ;;
        pendiente) next="viendo" ;;
        viendo) next="completado" ;;
        completado) next="" ;;
    esac
    if [ -f "$f" ]; then
        grep -v "^$1	" "$f" > "$f.new"; mv "$f.new" "$f"   # grep exit 1 si queda vacio: mv igual
    fi
    [ -n "$next" ] && printf '%s\t%s\t%s\n' "$1" "$2" "$next" >> "$f"
    printf '%s' "$next"
}

# ponytail: linea 2 de tarjeta de catalogo con marcas de fav/estado
catalog_card_l2() { # $1 id  $2 ep
    local l2="Ep $2"
    ani_fav_has "$1" && l2="$l2 ♥"
    local st; st=$(ani_watch_state "$1")
    [ -n "$st" ] && l2="$l2 [$st]"
    printf '%s' "$l2"
}

# ponytail: handler de teclas f/w del grid de catalogo — devuelve nueva linea 2
browse_grid_key() { # $1 key  $2 entry TSV (img,title,l2,slug,imgpath,ep)
    local slug title ep id
    slug=$(printf '%s' "$2" | cut -f4)
    title=$(printf '%s' "$2" | cut -f2)
    ep=$(printf '%s' "$2" | cut -f6)
    id="jkanime:${slug}"
    case "$1" in
        f) ani_fav_toggle "$id" "$title" ;;
        w) ani_watch_cycle "$id" "$title" >/dev/null ;;
        *) return 1 ;;
    esac
    catalog_card_l2 "$id" "$ep"
}

# ponytail: kitty graphics disponibles? (pixeles reales vs simbolos chafa)
has_kitty_graphics() {
    command -v kitten >/dev/null 2>&1 || return 1
    [ -n "$KITTY_WINDOW_ID" ] && return 0
    [ "$TERM" = "xterm-kitty" ] && return 0
    return 1
}

# ponytail: snippet de preview de imagen para fzf — icat nitido en kitty, chafa fallback
# $1 = expresion que evalua a la ruta de imagen dentro del preview (ej: {4})
img_preview_snippet() {
    if has_kitty_graphics; then
        printf '%s' "kitten icat --clear --transfer-mode=memory --unicode-placeholder --stdin=no --place=\"\${FZF_PREVIEW_COLUMNS}x\${FZF_PREVIEW_LINES}@0x0\" $1 | sed '\$d'"
    else
        printf '%s' "chafa $1 --size \"\${FZF_PREVIEW_COLUMNS}x\${FZF_PREVIEW_LINES}\" --format=symbols --animate off 2>/dev/null"
    fi
}

# ponytail: geometria del grid — top-level para poder testearla sin la TUI
# (bash dynamic scoping: lee/escribe las variables locales de show_card_grid).
# CG_COLS/CG_ROWS permiten inyectar dimensiones en tests (sin pty).
# layout responsive: recalculable en caliente (se llama tambien en SIGWINCH)
_cg_geom() {
    term_cols=${CG_COLS:-$(tput cols 2>/dev/null || echo 80)}
    term_rows=${CG_ROWS:-$(tput lines 2>/dev/null || echo 24)}
    ncols=$(( (term_cols - 2 * margin_x + gap_x) / (min_card_w + gap_x) ))
    [ "$ncols" -lt 1 ] && ncols=1
    card_w=$(( (term_cols - 2 * margin_x - (ncols - 1) * gap_x) / ncols ))
    # alto de imagen segun aspecto (celda ~1:2): poster vertical o screenshot 16:9
    if [ "$aspect" = "portrait" ]; then
        img_h=$(( (card_w - 4) * 5 / 7 ))
    else
        img_h=$(( (card_w - 4) * 2 / 7 ))
    fi
    [ "$img_h" -lt 6 ] && img_h=6
    card_h=$(( img_h + title_rows + 3 ))
    # clamp: la tarjeta siempre cabe en el viewport (ventanas muy bajas)
    local max_card_h=$(( term_rows - header_h ))
    if [ "$card_h" -gt "$max_card_h" ] && [ "$max_card_h" -ge 9 ]; then
        card_h=$max_card_h
        img_h=$(( card_h - title_rows - 3 ))
    fi
    vis_rows=$(( (term_rows - header_h) / card_h ))
    [ "$vis_rows" -lt 1 ] && vis_rows=1
    vrows=$(( (total + ncols - 1) / ncols ))
    # clamp: seleccion y viewport validos tras el resize
    [ "$sel" -ge "$total" ] && sel=$(( total - 1 ))
    local sel_row=$(( sel / ncols )) max_top=$(( vrows - vis_rows ))
    [ "$max_top" -lt 0 ] && max_top=0
    [ "$top" -gt "$max_top" ] && top=$max_top
    [ "$sel_row" -lt "$top" ] && top=$sel_row
    [ "$sel_row" -gt $(( top + vis_rows - 1 )) ] && top=$(( sel_row - vis_rows + 1 ))
}

# ponytail: grid de tarjetas generico con kitty graphics — scroll vertical continuo,
# el viewport sigue la seleccion (foco siempre visible), columnas responsive al ancho.
# $1 = data file (img\tlinea1\tlinea2\tpayload...) · $2 = etiqueta del header
# Enter imprime payload (campos 4+) y retorna 0 · q/Esc retorna 1
show_card_grid() {
    local data_file="$1" header_label="$2" aspect="${3:-landscape}"
    local min_card_w=22 margin_x=2 gap_x=2 title_rows=2 header_h=2
    local term_cols term_rows ncols card_w img_h card_h vis_rows vrows
    local entries=() total sel=0 top=0 cx cy

    mapfile -t entries < "$data_file"
    total=${#entries[@]}
    [ "$total" -eq 0 ] && return 1

    _cg_geom

    local c_accent=$'\033[38;5;141m' c_dim=$'\033[38;5;238m'
    local c_title=$'\033[38;5;252m' c_meta=$'\033[38;5;245m' c_r=$'\033[0m'

    _cg_cell_xy() { # $1 = indice visible (0..vis*ncols-1)
        local r=$(( $1 / ncols )) c=$(( $1 % ncols ))
        cx=$(( margin_x + c * (card_w + gap_x) ))
        cy=$(( header_h + r * card_h ))
    }
    _cg_border() { # $1 idx visible  $2 color
        local color="$2" inner=$(( card_w - 2 )) bh=$(( img_h + title_rows + 2 )) i hline
        _cg_cell_xy "$1"
        hline=$(printf '─%.0s' $(seq 1 $inner))
        tput cup "$cy" "$cx" >/dev/tty; printf '%s╭%s╮%s' "$color" "$hline" "$c_r" >/dev/tty
        for i in $(seq 1 $(( bh - 2 ))); do
            tput cup $(( cy + i )) "$cx" >/dev/tty; printf '%s│%s' "$color" "$c_r" >/dev/tty
            tput cup $(( cy + i )) $(( cx + card_w - 1 )) >/dev/tty; printf '%s│%s' "$color" "$c_r" >/dev/tty
        done
        tput cup $(( cy + bh - 1 )) "$cx" >/dev/tty; printf '%s╰%s%s╯%s' "$color" "$hline" "$color" "$c_r" >/dev/tty
    }
    _cg_card() { # $1 idx visible  $2 idx global
        local entry="${entries[$2]}" img l1 l2 t1 t2 maxw iw
        img=$(printf '%s' "$entry" | cut -f1)
        l1=$(printf '%s' "$entry" | cut -f2)
        l2=$(printf '%s' "$entry" | cut -f3)
        _cg_cell_xy "$1"
        iw=$(( card_w - 4 ))
        # unicode-placeholder: la imagen son celdas de texto → scrollea con CSI S/T
        # scale-up: llena el box manteniendo aspecto (sin esto, covers chicos flotan en el marco)
        [ -f "$img" ] && kitten icat --transfer-mode=memory --stdin=no --unicode-placeholder \
            --scale-up --place="${iw}x${img_h}@$(( cx + 2 ))x$(( cy + 1 ))" "$img" >/dev/tty 2>/dev/null
        maxw=$(( card_w - 4 ))
        t1="${l1:0:$maxw}"
        [ "${#l1}" -gt "$maxw" ] && t1="${t1:0:$(( maxw - 1 ))}…"
        t2="${l2:0:$maxw}"
        tput cup $(( cy + img_h + 1 )) $(( cx + 2 )) >/dev/tty; printf '%s%s%s' "$c_title" "$t1" "$c_r" >/dev/tty
        tput cup $(( cy + img_h + 2 )) $(( cx + 2 )) >/dev/tty; printf '%s%s%s' "$c_meta" "$t2" "$c_r" >/dev/tty
    }
    _cg_header() {
        local extra=""
        [ -n "$CG_ON_KEY" ] && extra=" · f ♥ · w lista"
        tput cup 0 "$margin_x" >/dev/tty
        tput el >/dev/tty
        printf '%s%s%s · %d títulos · fila %d/%d %s· ←↑↓→ mover · Enter ver%s · q salir%s' \
            "$c_accent" "$header_label" "$c_r$c_title" "$total" $(( sel / ncols + 1 )) "$vrows" "$c_meta" "$extra" "$c_r" >/dev/tty
    }
    _cg_paint() {
        clear >/dev/tty
        kitten icat --clear >/dev/tty 2>/dev/null
        _cg_header
        local i gidx
        for i in $(seq 0 $(( vis_rows * ncols - 1 ))); do
            gidx=$(( top * ncols + i ))
            [ "$gidx" -ge "$total" ] && break
            _cg_border "$i" "$c_dim"
            _cg_card "$i" "$gidx"
        done
        _cg_border $(( sel - top * ncols )) "$c_accent"
    }
    # scroll real: desplaza la region con CSI S/T (el contenido se corre) y pinta
    # solo las filas de tarjetas que entran — sin repintar todo el viewport
    _cg_scroll() { # $1 nuevo top
        local new_top=$1 delta=$(( $1 - top )) absd i gidx first last
        absd=${delta#-}
        if [ "$absd" -ge "$vis_rows" ]; then
            top=$new_top; _cg_paint; return
        fi
        local r_start=$(( header_h + 1 )) r_end=$(( header_h + vis_rows * card_h ))
        printf '\033[%d;%dr' "$r_start" "$r_end" >/dev/tty
        if [ "$delta" -gt 0 ]; then
            printf '\033[%dS' $(( delta * card_h )) >/dev/tty
            first=$(( vis_rows - delta )); last=$(( vis_rows - 1 ))
        else
            printf '\033[%dT' $(( absd * card_h )) >/dev/tty
            first=0; last=$(( absd - 1 ))
        fi
        printf '\033[r' >/dev/tty
        top=$new_top
        local row col vidx
        for row in $(seq "$first" "$last"); do
            for col in $(seq 0 $(( ncols - 1 ))); do
                vidx=$(( row * ncols + col ))
                gidx=$(( top * ncols + vidx ))
                [ "$gidx" -ge "$total" ] && break
                _cg_border "$vidx" "$c_dim"
                _cg_card "$vidx" "$gidx"
            done
        done
    }
    _cg_move() { # $1 nuevo sel global
        local new=$1
        [ "$new" -lt 0 ] && return
        [ "$new" -ge "$total" ] && return
        local new_row=$(( new / ncols )) old_vidx=$(( sel - top * ncols ))
        # viewport sigue la seleccion (scroll continuo, linea a linea de tarjetas)
        if [ "$new_row" -lt "$top" ]; then
            _cg_border "$old_vidx" "$c_dim"
            sel=$new
            _cg_scroll "$new_row"
        elif [ "$new_row" -gt $(( top + vis_rows - 1 )) ]; then
            _cg_border "$old_vidx" "$c_dim"
            sel=$new
            _cg_scroll $(( new_row - vis_rows + 1 ))
        else
            _cg_border "$old_vidx" "$c_dim"
            sel=$new
        fi
        _cg_border $(( sel - top * ncols )) "$c_accent"
        _cg_header
    }
    _cg_cleanup() {
        trap - WINCH
        kitten icat --clear >/dev/tty 2>/dev/null
        clear >/dev/tty
        tput cnorm >/dev/tty
    }

    tput civis >/dev/tty
    _cg_resized=""
    trap '_cg_resized=1' WINCH
    _cg_paint
    local key rest entry rc
    while true; do
        # timeout 1s: permite aplicar el resize sin esperar una tecla
        IFS= read -rsn1 -t 1 key </dev/tty
        rc=$?
        # resize de ventana: recomputar layout y repintar (responsive en vivo)
        if [ -n "$_cg_resized" ]; then
            _cg_resized=""
            _cg_geom
            _cg_paint
        fi
        # timeout o señal (no es tecla): seguir esperando
        [ "$rc" -ne 0 ] && continue
        if [ "$key" = $'\033' ]; then
            rest=""
            read -rsn2 -t 0.05 rest </dev/tty
            key="$key$rest"
        fi
        case "$key" in
            $'\033[C'|l) _cg_move $(( sel + 1 )) ;;
            $'\033[D'|h) _cg_move $(( sel - 1 )) ;;
            $'\033[B'|j) _cg_move $(( sel + ncols )) ;;
            $'\033[A'|k) _cg_move $(( sel - ncols )) ;;
            $'\033[6'|G) _cg_move $(( total - 1 )) ;;   # PgDn/G → final
            $'\033[5'|g) _cg_move 0 ;;                  # PgUp/g → inicio
            f|w)
                # hook opcional del caller: CG_ON_KEY procesa la tecla y devuelve nueva linea 2
                if [ -n "$CG_ON_KEY" ]; then
                    entry="${entries[$sel]}"
                    local new_l2
                    if new_l2=$("$CG_ON_KEY" "$key" "$entry"); then
                        entries[$sel]=$(printf '%s' "$entry" |
                            awk -F'\t' -v OFS='\t' -v l2="$new_l2" '{ $3 = l2; print }')
                        _cg_card $(( sel - top * ncols )) "$sel"
                    fi
                fi ;;
            ''|$'\n')
                entry="${entries[$sel]}"
                _cg_cleanup
                printf '%s' "$(printf '%s' "$entry" | cut -f4-)"
                return 0 ;;
            q|$'\033') _cg_cleanup; return 1 ;;
        esac
    done
}

# ponytail: catalogo con grid de tarjetas — arma data file (con marcas ♥/estado)
# y delega en show_card_grid con hook f/w activo
show_catalog_kitty() {
    local catalog_file="$1" img_dir="$2"
