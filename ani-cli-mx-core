select_allanime_ref() {
    cache_key="$1|$id"
    [ "$allanime_fallback_ref_key" = "$cache_key" ] && [ -n "$allanime_fallback_ref" ] && printf '%s\n' "$allanime_fallback_ref" && return 0

    explicit_allanime_id="$(allanime_id_from_ref "$id")"
    explicit_allanime_count="$(allanime_count_from_ref "$id")"
    if [ -n "$explicit_allanime_id" ] && [ -n "$explicit_allanime_count" ]; then
        allanime_fallback_ref="${explicit_allanime_id}|${explicit_allanime_count}"
        allanime_fallback_ref_key="explicit:$id"
        printf '%s\n' "$allanime_fallback_ref"
        return 0
    fi

    fallback_results="$(search_allanime_catalog "$1")"
    [ -z "$fallback_results" ] && return 1

    best_ref=""
    best_score=-999999
    old_ifs=$IFS
    IFS='
'
    for entry in $fallback_results; do
        candidate_id="$(printf '%s' "$entry" | cut -f1)"
        candidate_title="$(printf '%s' "$entry" | cut -f2)"
        candidate_count="$(printf '%s' "$entry" | cut -f3)"
        [ -z "$candidate_id" ] && continue
        [ -z "$candidate_count" ] && continue
        score="$(title_match_score "$1" "$candidate_id" "$candidate_title")"
        [ "$score" -gt "$best_score" ] && best_score="$score" && best_ref="${candidate_id}|${candidate_count}"
    done
    IFS=$old_ifs

    cross_source_match_is_confident "$best_score" || return 1
    [ -z "$best_ref" ] && best_ref="$(printf '%s\n' "$fallback_results" | sed -n '1p' | cut -f1,3 | tr '\t' '|')"
    [ -z "$best_ref" ] && return 1

    allanime_fallback_ref="$best_ref"
    allanime_fallback_ref_key="$cache_key"
    printf '%s\n' "$allanime_fallback_ref"
}

select_allanime_id() {
    allanime_ref="$(select_allanime_ref "$1")" || return 1
    printf '%s\n' "${allanime_ref%%|*}"
}

resolve_allanime_episode() {
    fallback_id="$(select_allanime_id "$1")" || return 1
    episode_embed_gql='query ($showId: String!, $translationType: VaildTranslationTypeEnumType!, $episodeString: String!) { episode( showId: $showId translationType: $translationType episodeString: $episodeString ) { episodeString sourceUrls }}'

    api_resp="$(curl -e "$english_source_refr" -s -H "Content-Type: application/json" -X POST "${english_source_api}/api" \
        --data "{\"variables\":{\"showId\":\"$fallback_id\",\"translationType\":\"$mode\",\"episodeString\":\"$2\"},\"query\":\"$episode_embed_gql\"}" -A "$agent")"
    if printf "%s" "$api_resp" | grep -q '"tobeparsed"'; then
        blob="$(printf "%s" "$api_resp" | sed -nE 's|.*"tobeparsed":"([^"]*)".*|\1|p')"
        resp="$(decode_tobeparsed "$blob")"
    else
        resp="$(printf "%s" "$api_resp" | tr '{}' '\n' | sed 's|\\u002F|\/|g;s|\\||g' | sed -nE 's|.*sourceUrl":"--([^"]*)".*sourceName":"([^"]*)".*|\2 :\1|p')"
    fi
    [ -z "$resp" ] && return 1

    cache_dir="$(mktemp -d)"
    providers="1 2 3 4"
    for provider in $providers; do
        allanime_generate_link "$provider" >"$cache_dir"/"$provider" &
    done
    wait
    links="$(cat "$cache_dir"/* | sort -g -r -s)"
    rm -r "$cache_dir"
    [ -n "$links" ] && printf '%s' "$links"
}

