    printf '%s' "$player_page" | tr '\n' ' ' |
        sed -nE "s|.*url: '([^']+)'.*|\\1|p" | head -n1
}

extract_jkanime_links() {
    jkanime_page="$1"
    internal_links=""
    player_entries="$(printf '%s' "$jkanime_page" | tr '\n' ' ' |
        grep -oE "video\\[[0-9]+\\][[:space:]]*=[[:space:]]*'<iframe[^']*src=\"[^\"]+\"" |
        sed -E 's|.*src="([^"]+)"$|\1|')"
    old_ifs=$IFS
    IFS='
'
    for player_url in $player_entries; do
        [ -z "$player_url" ] && continue
        case "$player_url" in
            /*) player_url="${jkanime_refr}${player_url}" ;;
        esac
        direct_link="$(extract_jkanime_internal_source "$player_url")"
        source_name="$(jkanime_internal_player_name "$player_url")"
        if [ -n "$direct_link" ]; then
            if ! printf '%s' "$internal_links" | grep -Fq ">${direct_link}"; then
                internal_links="${internal_links}$(jkanime_internal_player_priority "$player_url") >${direct_link}
referrer >${direct_link}>${player_url}
source >${direct_link}>${source_name}
site >${direct_link}>JKAnime
"
            fi
            source_status "$source_name" "ok"
            if fast_first_link_mode; then
                IFS=$old_ifs
                printf '%s' "$internal_links"
                return 0
            fi
        else
            source_status "$source_name" "skip"
        fi
    done
    IFS=$old_ifs

    [ -n "$internal_links" ] && printf '%s' "$internal_links" && return 0

    servers_json="$(printf '%s' "$jkanime_page" | tr '\n' ' ' | sed -nE 's|.*var servers = (\[[^;]*\]);.*|\1|p')"
    [ -z "$servers_json" ] && return 1

    primary_links=""
    entries="$(printf '%s' "$servers_json" | sed 's|^\[||; s|\]$||; s|},[[:space:]]*{|}\
{|g')"
    IFS='
'
    for entry in $entries; do
        [ -z "$entry" ] && continue
        server_name="$(printf '%s' "$entry" | sed -nE 's|.*"server":"([^"]*)".*|\1|p')"
        remote_b64="$(printf '%s' "$entry" | sed -nE 's|.*"remote":"([^"]*)".*|\1|p')"
        [ -z "$server_name" ] && continue
        [ -z "$remote_b64" ] && continue
        remote_url="$(printf '%s' "$remote_b64" | base64 -d 2>/dev/null | tr -d '\r\n')"
        [ -z "$remote_url" ] && continue

        source_name="JKAnime ${server_name}"
        direct_link=""
        case "$(printf '%s' "$server_name" | tr '[:upper:]' '[:lower:]')" in
            mega)
                :
                ;;
            mediafire)
                source_status "$source_name" "skip"
                ;;
            streamtape)
                direct_link="$(extract_streamtape_link "$remote_url")"
                if [ -n "$direct_link" ] && probe_stream_link "$remote_url" "$direct_link"; then
                    primary_links="${primary_links}$(jkanime_server_priority "$server_name") >${direct_link}
source >${direct_link}>${source_name}
site >${direct_link}>JKAnime
"
                    source_status "$source_name" "ok"
                    if fast_first_link_mode; then
                        IFS=$old_ifs
                        printf '%s' "$primary_links"
                        return 0
                    fi
                else
                    source_status "$source_name" "skip"
                fi
                ;;
            *)
                direct_link="$(extract_with_ytdlp "$remote_url")"
                if [ -n "$direct_link" ]; then
                    primary_links="${primary_links}$(jkanime_server_priority "$server_name") >${direct_link}
source >${direct_link}>${source_name}
site >${direct_link}>JKAnime
"
                    source_status "$source_name" "ok"
                    if fast_first_link_mode; then
                        IFS=$old_ifs
                        printf '%s' "$primary_links"
                        return 0
                    fi
                else
                    source_status "$source_name" "skip"
                fi
                ;;
        esac
    done
    IFS=$old_ifs

    [ -n "$primary_links" ] && printf '%s' "$primary_links"
}

