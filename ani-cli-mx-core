        auto) printf '%s\n' "Auto" ;;
        animeflv) printf '%s\n' "AnimeFLV" ;;
        jkanime) printf '%s\n' "JKAnime" ;;
        animeav1) printf '%s\n' "AnimeAV1" ;;
