jkanime_page_anime_id() {
    printf '%s' "$1" | tr '\n' ' ' |
        sed -nE "s|.*anime_checks\\('[^']*', '([0-9]+)'.*|\\1|p" | head -n1
}

jkanime_page_csrf_token() {
    printf '%s' "$1" | tr '\n' ' ' |
        sed -nE 's|.*<meta name="csrf-token" content="([^"]+)".*|\1|p' | head -n1
}

jkanime_ajax_episode_numbers() {
    slug="$1"
    cookie_jar="$(mktemp)"
    page_html="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s -c "$cookie_jar" "${jkanime_refr}/${slug}/" -A "$agent")" || {
        rm -f "$cookie_jar"
        return 1
    }

    anime_id="$(jkanime_page_anime_id "$page_html")"
    csrf_token="$(jkanime_page_csrf_token "$page_html")"
    if [ -z "$anime_id" ] || [ -z "$csrf_token" ]; then
        rm -f "$cookie_jar"
        return 1
    fi

    first_page="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s -b "$cookie_jar" -c "$cookie_jar" \
        -X POST "${jkanime_refr}/ajax/episodes/${anime_id}/1" --data "_token=${csrf_token}" \
        -H "X-Requested-With: XMLHttpRequest" -A "$agent")" || {
        rm -f "$cookie_jar"
        return 1
    }

    last_page="$(printf '%s' "$first_page" | sed -nE 's|.*"last_page":([0-9]+).*|\1|p' | head -n1)"
    [ -z "$last_page" ] && last_page=1

    episode_numbers="$(printf '%s' "$first_page" | grep -oE '"number":[0-9]+(\.[0-9]+)?' | cut -d: -f2)"
    page_no=2
    while [ "$page_no" -le "$last_page" ]; do
        page_json="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s -b "$cookie_jar" -c "$cookie_jar" \
            -X POST "${jkanime_refr}/ajax/episodes/${anime_id}/${page_no}" --data "_token=${csrf_token}" \
            -H "X-Requested-With: XMLHttpRequest" -A "$agent")" || break
        episode_numbers="${episode_numbers}
$(printf '%s' "$page_json" | grep -oE '"number":[0-9]+(\.[0-9]+)?' | cut -d: -f2)"
        page_no=$((page_no + 1))
    done

    rm -f "$cookie_jar"
    printf '%s\n' "$episode_numbers" | sed '/^$/d' | awk '!seen[$0]++' | sort -n -k 1
}

episodes_list_jkanime() {
    jkanime_match="$(show_ref_value_for_site "$1" "jkanime")"
    [ -z "$jkanime_match" ] && jkanime_match="$(select_jkanime_slug "$2")"
    [ -z "$jkanime_match" ] && return 1

    ajax_episode_numbers="$(jkanime_ajax_episode_numbers "$jkanime_match")"
    [ -n "$ajax_episode_numbers" ] && printf '%s\n' "$ajax_episode_numbers" && return 0

    jkanime_page="$(jkanime_request "${jkanime_refr}/${jkanime_match}/")" || return 1
    latest_ep="$(printf '%s' "$jkanime_page" | tr '\n' ' ' |
        sed -nE "s|.*https://jkanime\\.net/${jkanime_match}/([0-9.]+)/.*id=\"uep\".*|\\1|p")"
    [ -z "$latest_ep" ] && latest_ep="$(printf '%s' "$jkanime_page" | tr '\n' ' ' |
        sed -nE "s|.*https://jkanime\\.net/${jkanime_match}/([0-9.]+)/.*|\\1|p")"
    [ -z "$latest_ep" ] && return 1

    case "$latest_ep" in
        *.*) printf '%s\n' "$latest_ep" ;;
        *) awk -v max="$latest_ep" 'BEGIN { for (i = 1; i <= max; i++) print i }' ;;
    esac
}

episodes_list_allanime() {
    episode_count="$(allanime_count_from_ref "$1")" || return 1
    [ -z "$episode_count" ] && return 1
    awk -v max="$episode_count" 'BEGIN { for (i = 1; i <= max; i++) print i }'
}

episodes_list_for_source() {
    case "$1" in
        animeflv)
            animeflv_id="$(show_ref_value_for_site "$2" "animeflv")"
            [ -z "$animeflv_id" ] && [ "$2" = "${2#*:}" ] && animeflv_id="$2"
            [ -z "$animeflv_id" ] && animeflv_id="$(select_animeflv_id "$3")"
            [ -n "$animeflv_id" ] && episodes_list_animeflv "$animeflv_id"
            ;;
        jkanime)
            episodes_list_jkanime "$2" "$3"
            ;;
        animeav1)
            episodes_list_animeav1 "$2" "$3"
            ;;
        allanime)
            allanime_ref="$(show_ref_value_for_site "$2" "allanime")"
            [ -z "$allanime_ref" ] && allanime_ref="$(select_allanime_ref "$3")"
            [ -n "$allanime_ref" ] && episodes_list_allanime "allanime:${allanime_ref}"
            ;;
    esac
}

latest_episode_number() {
    printf '%s\n' "$1" | sed '/^$/d' | tail -n1 | tr -d '[:space:]'
}

episode_number_delta() {
    awk -v a="$1" -v b="$2" 'BEGIN { diff = a - b; if (diff < 0) diff = -diff; printf "%d\n", diff }'
}

episode_catalog_matches_authoritative() {
    authoritative_list="$1"
    candidate_list="$2"

    [ -n "$candidate_list" ] || return 1
    [ -n "$authoritative_list" ] || return 0

    authoritative_latest="$(latest_episode_number "$authoritative_list")"
    candidate_latest="$(latest_episode_number "$candidate_list")"
    [ -n "$authoritative_latest" ] || return 0
    [ -n "$candidate_latest" ] || return 0

    case "$authoritative_latest:$candidate_latest" in
        *[!0-9.:]*)
            [ -n "$ep_no" ] && printf '%s\n' "$candidate_list" | grep -qx "$ep_no"
            return $?
            ;;
    esac

    [ -n "$ep_no" ] && ! printf '%s\n' "$candidate_list" | grep -qx "$ep_no" && return 1
    delta="$(episode_number_delta "$authoritative_latest" "$candidate_latest")"
    [ "$delta" -le 2 ]
}

filter_links_by_episode_catalog() {
    site_name="$1"
    site_links="$2"
    authoritative_site="$3"
    authoritative_list="$4"

    [ -n "$site_links" ] || return 1
    [ -z "$authoritative_site" ] && printf '%s' "$site_links" && return 0
    [ "$site_name" = "$authoritative_site" ] && printf '%s' "$site_links" && return 0

    candidate_list="$(episodes_list_for_source "$site_name" "$id" "$title")"
    if episode_catalog_matches_authoritative "$authoritative_list" "$candidate_list"; then
        printf '%s' "$site_links"
    else
        printf "Descartando %s: catalogo no coincide con %s\n" "$(info_source_label "$site_name")" "$(info_source_label "$authoritative_site")" 1>&2
        return 1
    fi
}

episodes_list() {
    if [ "$preferred_info_source" != "auto" ]; then
        episodes="$(episodes_list_for_source "$preferred_info_source" "$1" "$2")"
        [ -n "$episodes" ] && printf '%s\n' "$episodes"
        return 0
    fi

    selected_site="$(site_name_from_ref "$1" 2>/dev/null || true)"
    episodes=""
    for site_name in "$selected_site" animeav1 jkanime allanime; do
        [ -n "$site_name" ] || continue
        [ -n "$episodes" ] && break
        episodes="$(episodes_list_for_source "$site_name" "$1" "$2")"
    done
    [ -n "$episodes" ] && printf '%s\n' "$episodes"
}

# PLAYING

process_hist_entry() {
    ep_list=$(episodes_list "$id" "$title")
    latest_ep=$(printf "%s\n" "$ep_list" | tail -n1)
    title=$(printf "%s\n" "$title" | sed "s|[0-9]\+ episodios|${latest_ep} episodios|")
    ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{n;p;}") 2>/dev/null
    [ -n "$ep_no" ] && printf "%s\t%s - episodio %s\n" "$id" "$title" "$ep_no"
}

last_watched_episode_for_current_anime() {
    [ -f "$histfile" ] || return 0
    awk -F '	' -v target="$id" '$2 == target { print $1; exit }' "$histfile"
}

select_episode() {
    stdin=$(cat -)
    [ -z "$stdin" ] && return 1
    line_count="$(printf "%s\n" "$stdin" | wc -l | tr -d "[:space:]")"
    [ "$line_count" -eq 1 ] && printf "%s" "$stdin" && return 0

    last_watched_ep="$(last_watched_episode_for_current_anime)"
    if [ -n "$last_watched_ep" ] && ! printf "%s\n" "$stdin" | awk -v last_ep="$last_watched_ep" '$0 == last_ep { found = 1 } END { exit !found }'; then
        last_watched_ep=""
    fi
    prompt="Selecciona episodio: "
    [ -n "$last_watched_ep" ] && prompt="Selecciona episodio (* ultimo visto): "
    menu_entries="$(printf "%s\n" "$stdin" | awk -v last_ep="$last_watched_ep" '
        last_ep != "" && $0 == last_ep { print $0 " *"; next }
        { print }
    ')"
    selection="$(printf "%s" "$menu_entries" | launcher "$multi_selection_flag" "$prompt")"
    selected_eps="$(printf "%s\n" "$selection" | sed 's/[[:space:]].*$//')"
    [ -n "$selected_eps" ] || exit 1

    line_start=$(printf "%s" "$selected_eps" | head -n1)
    line_end=$(printf "%s" "$selected_eps" | tail -n1)
    if [ "$line_start" = "$line_end" ]; then
        printf "%s" "$line_start"
    else
        printf "%s\n" "$stdin" | awk -v start="$line_start" -v end="$line_end" '
            $0 == start { printing = 1 }
            printing { print }
            $0 == end { exit }
        '
    fi
}

update_history() {
    awk -F '	' -v OFS='	' -v target="$id" -v new_ep="$ep_no" -v new_title="$title" '
        BEGIN { updated = 0 }
        $2 == target {
            $1 = new_ep
            $3 = new_title
            updated = 1
        }
        NF { print }
        END {
            if (!updated) {
                print new_ep, target, new_title
            }
        }
    ' "$histfile" >"${histfile}.new"
    mv "${histfile}.new" "$histfile"
}

download() {
    # download subtitle if it's set
    [ -n "$subtitle" ] && curl -s "$subtitle" -o "$download_dir/$2.vtt"
    case $1 in
        *m3u8*)
            if command -v "yt-dlp" >/dev/null; then
                yt-dlp --referer "$m3u8_refr" "$1" --no-skip-unavailable-fragments --fragment-retries infinite -N 16 -o "$download_dir/$2.mp4"
            else
                ffmpeg -extension_picky 0 -referer "$m3u8_refr" -loglevel error -stats -i "$1" -c copy "$download_dir/$2.mp4"
            fi
            # embed subs into downloads
            # [ -e "$download_dir/$2.vtt" ] && ffmpeg -i "$download_dir/$2.mp4" -i "$download_dir/$2.vtt" -c copy -c:s mov_text "$download_dir/$2.bak.mp4" && mv "$download_dir/$2.bak.mp4" "$download_dir/$2.mp4"
            ;;
        *)
            # shellcheck disable=SC2086
            aria2c --referer="$allanime_refr" --enable-rpc=false --check-certificate=false --continue $iSH_DownFix --summary-interval=0 -x 16 -s 16 "$1" --dir="$download_dir" -o "$2.mp4" --download-result=hide
            ;;
    esac
}

play_episode() {
    manual_handoff=0
    player_pid=""
    set_current_episode "$ep_no"
    [ "$log_episode" = 1 ] && [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && command -v logger >/dev/null && logger -t "$log_tag" "${allanime_title}${ep_no}"
    [ "$skip_intro" = 1 ] && skip_flag="$(ani-skip -q "$mal_id" -e "$ep_no")"
    [ -z "$episode" ] && get_episode_url
    if [ "$selected_source" = "HQQ" ] && [ "$hqq_browser_fallback" = "1" ] &&
        [ -n "$generic_refr" ] && [ "$player_function" != "debug" ] && [ "$player_function" != "download" ]; then
        printf "Fuente seleccionada: %s\n" "${selected_origin:-$selected_source}" 1>&2
        printf "HQQ requiere desbloqueo manual.\n" 1>&2
        printf "Abre esta URL:\n%s\n" "$generic_refr" 1>&2
        if open_browser_url "$generic_refr"; then
            printf "Abriendo navegador...\n" 1>&2
        fi
        manual_handoff=1
    fi
    # shellcheck disable=SC2086
    case "$player_function" in
        debug)
            printf "Todos los enlaces:\n%s\nFuente seleccionada:\n%s\n" "$links" "${selected_origin:-desconocida}"
            [ "$selected_source" = "HQQ" ] && [ -n "$generic_refr" ] && printf "Accion manual HQQ:\n%s\n" "$generic_refr"
            printf "Enlace seleccionado:\n"
            printf "%s\n" "$episode"
            ;;
        mpv* | */mpv | */mpv.exe)
            [ -n "$selected_origin" ] && [ "$manual_handoff" = 0 ] && printf "Fuente seleccionada: %s\n" "$selected_origin" 1>&2
            if [ "$manual_handoff" = 1 ]; then
                :
            elif [ "$no_detach" = 0 ]; then
                nohup $player_function $skip_flag --force-media-title="${allanime_title}Episode ${ep_no}" "$episode" $subs_flag $refr_flag >/dev/null 2>&1 &
                player_pid=$!
            else
                $player_function $skip_flag $subs_flag $refr_flag --force-media-title="${allanime_title}Episode ${ep_no}" "$episode"
                mpv_exitcode=$?
                [ "$exit_after_play" = 1 ] && [ -z "$range" ] && exit "$mpv_exitcode"
            fi
            ;;
        android_mpv) nohup am start --user 0 -a android.intent.action.VIEW -d "$episode" -n is.xyz.mpv/.MPVActivity >/dev/null 2>&1 & ;;
        android_vlc) nohup am start --user 0 -a android.intent.action.VIEW -d "$episode" -n org.videolan.vlc/org.videolan.vlc.gui.video.VideoPlayerActivity -e "title" "${allanime_title}Episode ${ep_no}" >/dev/null 2>&1 & ;;
        *iina*)
            [ -n "$subs_flag" ] && subs_flag="--mpv-${subs_flag#--}"
            [ -n "$refr_flag" ] && refr_flag="--mpv-${refr_flag#--}"
            if pgrep -f "IINA" >/dev/null 2>&1; then
                # omit --keep-running when an IINA instance exists to prevent hanging
                nohup $player_function --no-stdin --mpv-force-media-title="${allanime_title}Episode ${ep_no}" $subs_flag $refr_flag "$episode" >/dev/null 2>&1 &
            else
                nohup $player_function --no-stdin --keep-running --mpv-force-media-title="${allanime_title}Episode ${ep_no}" $subs_flag $refr_flag "$episode" >/dev/null 2>&1 &
            fi
            ;;
        flatpak_mpv)
            if [ "$no_detach" = 0 ]; then
                flatpak run io.mpv.Mpv --force-media-title="${allanime_title}Episode ${ep_no}" "$episode" $subs_flag $refr_flag >/dev/null 2>&1 &
                player_pid=$!
            else
                flatpak run io.mpv.Mpv --force-media-title="${allanime_title}Episode ${ep_no}" "$episode" $subs_flag $refr_flag
                mpv_exitcode=$?
                [ "$exit_after_play" = 1 ] && [ -z "$range" ] && exit "$mpv_exitcode"
            fi
            ;;
        vlc*) nohup $player_function --http-referrer="${allanime_refr}" --play-and-exit --meta-title="${allanime_title}Episode ${ep_no}" "$episode" >/dev/null 2>&1 & ;;
        *yncpla*) nohup $player_function "$episode" -- --force-media-title="${allanime_title}Episode ${ep_no}" $subs_flag $refr_flag >/dev/null 2>&1 & ;;
        download) "$player_function" "$episode" "${allanime_title}Episode ${ep_no}" "$subtitle" ;;
        catt) nohup catt cast "$episode" -s "$subtitle" >/dev/null 2>&1 & ;;
        iSH)
            printf "\e]8;;vlc://%s\a~~~~~~~~~~~~~~~~~~~~\n~ Tap to open VLC ~\n~~~~~~~~~~~~~~~~~~~~\e]8;;\a\n" "$episode"
            sleep 5
            ;;
        *) nohup $player_function "$episode" >/dev/null 2>&1 & ;;
    esac
    replay="$episode"
    unset episode
    [ "$manual_handoff" = 1 ] || update_history
    [ "$manual_handoff" = 1 ] && [ "$exit_after_play" = 1 ] && [ -z "$range" ] && exit 0
    [ "$use_external_menu" = "1" ] && wait
    [ "$use_external_menu" = "2" ] && wait
}

play() {
    start=$(printf "%s" "$ep_no" | grep -Eo '^(-1|[0-9]+(\.[0-9]+)?)')
    end=$(printf "%s" "$ep_no" | grep -Eo '(-1|[0-9]+(\.[0-9]+)?)$')
    [ "$start" = "-1" ] && ep_no=$(printf "%s" "$ep_list" | tail -n1) && unset start
    [ -z "$end" ] || [ "$end" = "$start" ] && unset start end
    [ "$end" = "-1" ] && end=$(printf "%s" "$ep_list" | tail -n1)
    line_count=$(printf "%s\n" "$ep_no" | wc -l | tr -d "[:space:]")
    if [ "$line_count" != 1 ] || [ -n "$start" ]; then
        [ -z "$start" ] && start=$(printf "%s\n" "$ep_no" | head -n1)
        [ -z "$end" ] && end=$(printf "%s\n" "$ep_no" | tail -n1)
        range=$(printf "%s\n" "$ep_list" | sed -nE "/^${start}\$/,/^${end}\$/p")
        [ -z "$range" ] && die "Invalid range!"
        for i in $range; do
            tput clear
            ep_no=$i
            printf "\33[2K\r\033[1;34mReproduciendo episodio %s...\033[0m\n" "$ep_no"
            [ "$i" = "$end" ] && unset range
            play_episode
        done
    else
        play_episode
    fi
    # moves up to stored position and deletes to end
    [ "$player_function" != "debug" ] && [ "$player_function" != "download" ] && tput rc && tput ed
}

set_current_episode() {
    [ -n "$1" ] && printf '%s\n' "$1" >"$current_episode_file"
}

current_episode_number() {
    if [ -s "$current_episode_file" ]; then
        sed -n '1p' "$current_episode_file"
    else
        printf '%s\n' "$ep_no"
    fi
}

sync_current_episode() {
    synced_ep="$(current_episode_number)"
    [ -n "$synced_ep" ] && ep_no="$synced_ep"
}

next_episode_number() {
    current_ep="${1:-$ep_no}"
    printf "%s\n" "$ep_list" | sed -n "/^${current_ep}$/{n;p;}" | head -n1
}

play_continuous() {
    while next_ep="$(next_episode_number "$(current_episode_number)")" && [ -n "$next_ep" ]; do
        ep_no="$next_ep"
        set_current_episode "$ep_no"
        printf "\33[2K\r\033[1;34mReproduciendo episodio %s...\033[0m\n" "$ep_no"
        play_episode
    done
    printf "No hay mas episodios disponibles.\n" 1>&2
}

player_supports_continuous() {
    case "$player_function" in
        mpv* | */mpv | mpv.exe | */mpv.exe | flatpak_mpv) return 0 ;;
        *) return 1 ;;
    esac
}

continuous_enabled() {
    [ -f "$continuous_state_file" ] && grep -qx "1" "$continuous_state_file"
}

set_continuous_mode() {
    continuous_mode="$1"
    printf '%s\n' "$1" >"$continuous_state_file"
}

disable_continuous_mode() {
    set_continuous_mode 0
    [ -n "${continuous_worker_pid:-}" ] && kill "$continuous_worker_pid" 2>/dev/null || true
    continuous_worker_pid=""
}

close_previous_enabled() {
    [ "$close_previous_player" = "1" ]
}

set_close_previous_mode() {
    close_previous_player="$1"
}

close_tracked_player() {
    [ -n "${player_pid:-}" ] || return 0
    kill -0 "$player_pid" 2>/dev/null || return 0
    kill "$player_pid" 2>/dev/null || true
    wait "$player_pid" 2>/dev/null || true
    player_pid=""
}

prepare_for_menu_playback() {
    if close_previous_enabled; then
        close_tracked_player
    fi
}

start_continuous_worker_for_current_player() {
    continuous_enabled || return 1
    player_supports_continuous || return 1
    [ -n "${player_pid:-}" ] || return 1
    kill -0 "$player_pid" 2>/dev/null || return 1

    [ -n "${continuous_worker_pid:-}" ] && kill "$continuous_worker_pid" 2>/dev/null || true
    continuous_worker_loop "$player_pid" &
    continuous_worker_pid=$!
    return 0
}

wait_for_pid_to_exit() {
    [ -n "$1" ] || return 0
    while kill -0 "$1" 2>/dev/null; do
        sleep 1
    done
}

continuous_worker_loop() {
    watched_pid="$1"
    wait_for_pid_to_exit "$watched_pid"
    while continuous_enabled; do
        next_ep="$(next_episode_number "$(current_episode_number)")"
        if [ -z "$next_ep" ]; then
            set_continuous_mode 0
            printf "No hay mas episodios disponibles.\n" 1>&2
            return 0
        fi

        ep_no="$next_ep"
        set_current_episode "$ep_no"
        printf "\33[2K\r\033[1;34mReproduciendo episodio %s...\033[0m\n" "$ep_no"
        play_episode
        wait_for_pid_to_exit "${player_pid:-}"
    done
}

toggle_continuous_mode_from_menu() {
    if continuous_enabled; then
        disable_continuous_mode
        printf "Modo continuo desactivado.\n" 1>&2
        return 0
    fi

    if ! player_supports_continuous; then
        printf "Modo continuo requiere mpv para detectar cuando termina el episodio\n" 1>&2
        return 1
    fi

    set_continuous_mode 1
    if start_continuous_worker_for_current_player; then
        printf "Modo continuo activado. Se abrira el siguiente capitulo al terminar o cerrar el reproductor actual.\n" 1>&2
    else
        printf "Modo continuo activado. El proximo capitulo que reproduzcas avanzara automaticamente al terminar o cerrar el reproductor.\n" 1>&2
    fi
}

toggle_close_previous_from_menu() {
    if close_previous_enabled; then
        set_close_previous_mode 0
        printf "Cerrar reproductor anterior desactivado.\n" 1>&2
    else
        set_close_previous_mode 1
        printf "Cerrar reproductor anterior activado. Al abrir otro episodio desde el menu, se cerrara el reproductor observado anterior.\n" 1>&2
    fi
}

playback_menu_options() {
    printf "siguiente\nanterior\nrepetir_episodio_actual\nelegir_episodio\ncambiar_calidad\n"
    if continuous_enabled; then
        printf "desactivar_modo_continuo\n"
    else
        printf "activar_modo_continuo\n"
    fi
    if close_previous_enabled; then
        printf "desactivar_cerrar_reproductor_anterior\n"
    else
        printf "activar_cerrar_reproductor_anterior\n"
    fi
    printf "salir\n"
}

playback_menu_prompt() {
    menu_ep="$(current_episode_number)"
    if continuous_enabled; then
        playback_mode="continuo"
        playback_note="el proximo capitulo reproducido avanzara automaticamente"
    else
        playback_mode="manual"
        playback_note="elige manualmente el siguiente capitulo"
    fi
    if close_previous_enabled; then
        close_note="cerrar anterior: si"
    else
        close_note="cerrar anterior: no"
    fi
    printf "Reproduciendo episodio %s de %s... Modo actual: %s - %s - %s" "$menu_ep" "$title" "$playback_mode" "$playback_note" "$close_note"
}

