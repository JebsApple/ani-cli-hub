extract_animeav1_entries() {
    [ -z "$1" ] && return 1
    printf '%s' "$1" | sed "s|.*$2:\\[||" |
        sed 's|],*[A-Z][A-Z0-9]*:\[.*||; s|]$||; s|},{|}\
{|g'
