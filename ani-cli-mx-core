# ponytail: scrapes jkanime.net/horario, groups by day, downloads thumbnails
# output: slug\ttitle\tdayslug\tthumb_path
fetch_weekly_schedule() {
    local schedule_html schedule_file tmpdir
    schedule_html=$(curl -s -L -A "$agent" "${jkanime_refr}/horario") || return 1
    schedule_file=$(mktemp) || return 1
    tmpdir=$(mktemp -d) || { rm -f "$schedule_file"; return 1; }
    printf '%s\n' "$schedule_html" | tr '\n' ' ' |
        sed 's|<div class=.box semana.|\n@DAY@|g;s|<div title=|\n@ENTRY@|g' |
        awk '
            /^@DAY@/ {
                day = $0
                sub(/.*<\/i> */, "", day)
                sub(/<.*/, "", day)
                gsub(/[^a-zA-Záéíóúñ ]/, "", day)
                gsub(/^ +| +$/, "", day)
                dayslug = tolower(day)
            }
            /^@ENTRY@/ {
                if (match($0, /title="([^"]+)"/, t) && match($0, /href="([^"]+)"/, h) && match($0, /src="([^"]+)"/, s)) {
                    slug = h[1]
                    gsub(/https:\/\/jkanime\.net\//, "", slug)
                    gsub(/\/$/, "", slug)
                    epcap = "?"
                    if (match($0, /[Úú]ltimo[ .]cap[ít]+ulo[ :]+([0-9]+)/, e)) epcap = e[1]
                    printf "%s\t%s\t%s\t%s\t%s\n", slug, t[1], dayslug, s[1], epcap
                }
            }
        ' > "$schedule_file"
    export SCHEDULE_FILE="$schedule_file"
    export SCHEDULE_TMPDIR="$tmpdir"
}

# ponytail: schedule with chafa thumbnails + episode button bar
show_schedule_with_thumbnails() {
    local schedule_file="$1"
    # Compute preview sizes from terminal dimensions
    local term_cols term_rows prev_cols img_rows
    term_cols=$(tput cols 2>/dev/null || echo 80)
    term_rows=$(tput lines 2>/dev/null || echo 24)
    prev_cols=$(( term_cols * 55 / 100 - 6 ))
    [ "$prev_cols" -lt 20 ] && prev_cols=20
    img_rows=$(( term_rows - 7 ))
    [ "$img_rows" -lt 8 ] && img_rows=8
    while true; do
    # Stage 1: pick day
    local day_index
    day_index=$(printf '%s\n' "1 Lunes" "2 Martes" "3 Miércoles" "4 Jueves" "5 Viernes" "6 Sábado" "7 Domingo" "← Salir" \
        | fzf --reverse --cycle --prompt " Elegir día → " --height=20 \
        --border rounded --margin 1 --padding 1)
    [ -z "$day_index" ] && return 1
    echo "$day_index" | grep -q "Salir" && return 1
    local selected_day
    selected_day=$(printf '%s' "$day_index" | cut -d' ' -f2 | tr '[:upper:]' '[:lower:]')
    while true; do
    # Stage 2: show animes for that day
    local day_animes count
    day_animes=$(awk -F'\t' -v d="$selected_day" '$3 == d' "$schedule_file")
    count=$(printf '%s\n' "$day_animes" | wc -l)
    [ "$count" -eq 0 ] && break
    # Download thumbnails
    if [ -d "$SCHEDULE_TMPDIR" ]; then
        local slug thumb img_path pids_file
        pids_file=$(mktemp)
        while IFS= read -r entry; do
            slug=$(printf '%s' "$entry" | cut -f1)
            thumb=$(printf '%s' "$entry" | cut -f4)
            img_path="${SCHEDULE_TMPDIR}/${slug}.jpg"
            [ -f "$img_path" ] && continue
            curl -s -o "$img_path" "$thumb" &
            echo $! >> "$pids_file"
        done <<< "$day_animes"
        while read -r pid; do wait "$pid" 2>/dev/null; done < "$pids_file"
        rm -f "$pids_file"
    fi
    # Build menu with back button: num slug title epcap imgpath
    local menu
    menu=$(printf '%s\n' "$day_animes" | awk -F'\t' -v dir="$SCHEDULE_TMPDIR" '{ printf "%d\t%s\t%s\t%s\t%s/%s.jpg\n", NR, $1, $2, $5, dir, $1 }')
    menu=$(printf '%s\n%s' "$(printf '←\tVolver al día\t\t\t')" "$menu")
    # Preview: chafa sized to panel + episode button bar
    local preview_cmd
    local sched_img_cmd
    if has_kitty_graphics; then
        sched_img_cmd="kitten icat --clear --transfer-mode=memory --unicode-placeholder --stdin=no --place=\"\${FZF_PREVIEW_COLUMNS}x\$(( FZF_PREVIEW_LINES - 8 ))@0x0\" \"\$img\" | sed '\$d'"
    else
        sched_img_cmd="chafa \"\$img\" --size ${prev_cols}x${img_rows} --format=symbols --animate off 2>/dev/null"
    fi
    preview_cmd="case {2} in
    \"Volver al día\") printf '\033[38;5;244m  ← Volver al selector de días\033[0m\n' ;;
    *)
        img={5}
        epcap={4}
        if [ -f \"\$img\" ]; then
            ${sched_img_cmd}
            echo \"\"
            if [ \"\$epcap\" != \"?\" ] && [ \"\$epcap\" -gt 0 ] 2>/dev/null; then
                printf \"\033[38;5;240m  ╭── Capítulos ──\033[0m\"
                printf \"\033[38;5;240m───────────────────────────────╮\033[0m\n\"
                printf \"\033[38;5;240m  │\033[0m \"
                for i in \$(seq 1 \"\$epcap\"); do
                    printf \"\033[48;5;236m\033[38;5;252m %s \033[0m \" \"\$i\"
                done
                printf \"\033[38;5;240m│\033[0m\n\"
                printf \"\033[38;5;240m  ╰────────────────────────────────────────╯\033[0m\n\"
            else
                printf \"\033[38;5;245m  sin datos de episodios\033[0m\n\"
            fi
        fi
        ;;
esac"
    local result
    result=$(printf '%s\n' "$menu" | fzf --reverse --cycle \
        --prompt " ${selected_day} → " \
        --delimiter '\t' \
        --with-shell 'sh -c' \
        --preview "$preview_cmd" \
        --preview-window="right:${prev_cols}:wrap" \
        --border rounded --margin 1 --padding 1 \
        --bind 'tab:accept')
    [ -z "$result" ] && break  # Esc → back to day picker
    echo "$result" | grep -q "Volver" && break  # ← Volver al día
    # Got anime → return slug + img_path
    printf '%s\t%s' "$(printf '%s' "$result" | cut -f2)" "$(printf '%s' "$result" | cut -f5)"
    return 0
    done
    done
    return 1
}

# ponytail: select_episode variant that shows chafa thumbnail in preview
select_episode_with_image() {
    local img_path="$1"
    stdin=$(cat -)
    [ -z "$stdin" ] && return 1
    line_count="$(printf "%s\n" "$stdin" | wc -l | tr -d "[:space:]")"
    [ "$line_count" -eq 1 ] && printf "%s" "$stdin" && return 0

    last_watched_ep="$(last_watched_episode_for_current_anime)"
    if [ -n "$last_watched_ep" ] && ! printf "%s\n" "$stdin" | awk -v last_ep="$last_watched_ep" '$0 == last_ep { found = 1 } END { exit !found }'; then
        last_watched_ep=""
    fi
    prompt="Selecciona episodio: "
    [ -n "$last_watched_ep" ] && prompt="Selecciona episodio (* ultimo visto): "
    menu_entries="$(printf "%s\n" "$stdin" | awk -v last_ep="$last_watched_ep" '
        last_ep != "" && $0 == last_ep { print $0 " *"; next }
        { print }
    ')"
    local ep_preview_cmd=""
    [ -n "$img_path" ] && [ -f "$img_path" ] && ep_preview_cmd="$(img_preview_snippet "\"$img_path\"")"
    if [ -n "$ep_preview_cmd" ]; then
        selection="$(printf "%s" "$menu_entries" | fzf --reverse --cycle \
            --prompt "$prompt" \
            --with-shell 'sh -c' \
            --preview "$ep_preview_cmd" \
            --preview-window=right:55%:wrap \
            --border rounded --margin 1 --padding 1)"
    else
        selection="$(printf "%s" "$menu_entries" | launcher "$multi_selection_flag" "$prompt")"
    fi
    selected_eps="$(printf "%s\n" "$selection" | sed 's/[[:space:]].*$//')"
    [ -n "$selected_eps" ] || exit 1

    line_start=$(printf "%s" "$selected_eps" | head -n1)
    line_end=$(printf "%s" "$selected_eps" | tail -n1)
    if [ "$line_start" = "$line_end" ]; then
        printf "%s" "$line_start"
    else
        printf "%s\n" "$stdin" | awk -v start="$line_start" -v end="$line_end" '
            $0 == start { printing = 1 }
            printing { print }
            $0 == end { exit }
        '
    fi
}

select_animeflv_id() {
    cache_key="$1|$id"
    [ "$animeflv_selected_id_key" = "$cache_key" ] && [ -n "$animeflv_selected_id" ] && printf '%s\n' "$animeflv_selected_id" && return 0

    animeflv_results="$(search_animeflv_variants "$1")"
    [ -z "$animeflv_results" ] && return 1

    best_id=""
    best_score=-999999
    old_ifs=$IFS
    IFS='
'
    for entry in $animeflv_results; do
        candidate_id="$(printf '%s' "$entry" | cut -f1)"
        candidate_title="$(printf '%s' "$entry" | cut -f2)"
        [ -z "$candidate_id" ] && continue
        score="$(title_match_score "$1" "$candidate_id" "$candidate_title")"
        [ "$score" -gt "$best_score" ] && best_score="$score" && best_id="$candidate_id"
    done
    IFS=$old_ifs

    cross_source_match_is_confident "$best_score" || return 1
    [ -z "$best_id" ] && best_id="$(printf '%s\n' "$animeflv_results" | sed -n '1p' | cut -f1)"
    [ -z "$best_id" ] && return 1

    animeflv_selected_id="$best_id"
    animeflv_selected_id_key="$cache_key"
    printf '%s\n' "$animeflv_selected_id"
}

