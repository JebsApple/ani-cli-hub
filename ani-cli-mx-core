    esac
fi
printf "\33[2K\r\033[1;34mVerificando dependencias...\033[0m\n"
dep_ch "curl" "sed" "grep" || true
case "$(uname -o 2>/dev/null)" in
    *ndroid*) command -v openssl >/dev/null || die 'No se encontro "openssl". En Termux instalalo con: pkg install openssl-tool' ;;
    *) dep_ch "openssl" || true ;;
esac
[ "$skip_intro" = 1 ] && (dep_ch "ani-skip" || true)
dep_ch "fzf" || true
case "$search" in schedule|browse|favs|watchlist) dep_ch "chafa" || true ;; esac
case "$player_function" in
    debug) ;;
    download) dep_ch "ffmpeg" "aria2c" ;;
    android*) printf "\33[2K\rChecking of players on Android is disabled\n" ;;
    *iSH*) printf "\33[2K\rChecking of players on iOS is disabled\n" ;;
    flatpak_mpv) true ;; # handled out of band in where_mpv
    *) dep_ch "$player_function" ;;
esac

# searching
case "$search" in
    history)
        anime_list=$(while read -r ep_no id title; do process_hist_entry & done <"$histfile")
        wait
        [ -z "$anime_list" ] && die "No hay series pendientes en el historial"
        [ -z "${index##*[!0-9]*}" ] && id=$(printf "%s" "$anime_list" | nl -w 2 | sed 's/^[[:space:]]//' | nth "Selecciona anime: " | cut -f1)
        [ -z "${index##*[!0-9]*}" ] || id=$(printf "%s" "$anime_list" | sed -n "${index}p" | cut -f1)
        [ -z "$id" ] && exit 1
        title=$(printf "%s\n" "$anime_list" | awk -F '	' -v target="$id" '$1 == target { print $2; exit }' | sed 's/ - episodio.*//')
        ep_list=$(episodes_list "$id" "$title")
        ep_no=$(printf "%s\n" "$anime_list" | awk -F '	' -v target="$id" '$1 == target { print $2; exit }' |
            sed -nE 's/.*- episodio (.+)$/\1/p')
        allanime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        ;;
    recent)
        recent_list=$(fetch_recent_releases)
        [ -z "$recent_list" ] && die "No se encontraron episodios recientes"
        recent_menu="$(printf "%s\n" "$recent_list" | awk -F '\t' '{ printf "%d\t%s\t%s - Ep %s\n", NR, $1, $2, $3 }')"
        result="$(printf "%s" "$recent_menu" | nth "Selecciona episodio reciente: ")"
        [ -z "$result" ] && exit 1
        id=$(printf "%s" "$result" | cut -f1)
        title=$(printf "%s\n" "$recent_list" | awk -F '\t' -v target="$id" '$1 == target { print $2; exit }')
        ep_no=$(printf "%s\n" "$recent_list" | awk -F '\t' -v target="$id" '$1 == target { print $3; exit }')
        allanime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        ep_list=$(episodes_list "$id" "$title")
        ;;
    schedule)
        fetch_weekly_schedule
        [ -z "$SCHEDULE_FILE" ] || [ ! -s "$SCHEDULE_FILE" ] && die "No se pudo obtener el horario semanal"
        result="$(show_schedule_with_thumbnails "$SCHEDULE_FILE")"
        [ -z "$result" ] && rm -rf "$SCHEDULE_TMPDIR" 2>/dev/null && rm -f "$SCHEDULE_FILE" 2>/dev/null && exit 1
        id=$(printf "%s" "$result" | cut -f1)
        img_path=$(printf "%s" "$result" | cut -f2)
        title=$(awk -F'\t' -v target="$id" '$1 == target { print $2; exit }' "$SCHEDULE_FILE")
        id="jkanime:${id}"   # horario viene de jkanime: prefijar para que episodes_list use el slug directo
        rm -f "$SCHEDULE_FILE" 2>/dev/null
        allanime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        ep_list=$(episodes_list "$id" "$title")
        if has_kitty_graphics; then
            ep_no=$(printf "%s\n" "$ep_list" | select_episode_grid "$id" "$img_path")
        else
            ep_no=$(printf "%s\n" "$ep_list" | select_episode_with_image "$img_path")
        fi
        rm -rf "$SCHEDULE_TMPDIR" 2>/dev/null
        [ -z "$ep_no" ] && exit 1
        ;;
    browse | favs | watchlist)
        fetch_browse_catalog
        [ -z "$CATALOG_FILE" ] || [ ! -s "$CATALOG_FILE" ] && die "No se pudo obtener el catalogo"
        # CATALOG_FILE/CATALOG_TMPDIR viven en ~/.cache — no borrar
        # favs/watchlist: mismo grid, catalogo filtrado por los archivos de estado
        if [ "$search" = "favs" ] || [ "$search" = "watchlist" ]; then
            state_src="$hist_dir/ani-favs"
            [ "$search" = "watchlist" ] && state_src="$hist_dir/ani-watchlist"
            [ -s "$state_src" ] || die "Sin entradas en $search todavia (usa f/w en el catalogo)"
            filtered_catalog=$(mktemp)
            awk -F'\t' 'NR==FNR { ids[$1]; next } ("jkanime:" $1) in ids' \
                "$state_src" "$CATALOG_FILE" > "$filtered_catalog"
            [ -s "$filtered_catalog" ] || die "Nada de tu $search esta en el catalogo actual"
            CATALOG_FILE="$filtered_catalog"
        fi
        result="$(show_browse_grid "$CATALOG_FILE" "$CATALOG_TMPDIR")"
        [ -z "$result" ] && exit 1
        id=$(printf "%s" "$result" | cut -f1)
        img_path=$(printf "%s" "$result" | cut -f2)
        title=$(awk -F'\t' -v target="$id" '$1 == target { print $2; exit }' "$CATALOG_FILE")
        id="jkanime:${id}"   # catalogo viene de jkanime: prefijar para que episodes_list use el slug directo
        [ -n "$ANI_DEBUG" ] && printf 'DBG id=[%s] img=[%s] title=[%s]\n' "$id" "$img_path" "$title" >&2
        allanime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        ep_list=$(episodes_list "$id" "$title")
        [ -n "$ANI_DEBUG" ] && printf 'DBG ep_list=[%s]\n' "$(printf '%s' "$ep_list" | tr '\n' ',')" >&2
        if has_kitty_graphics; then
            ep_no=$(printf "%s\n" "$ep_list" | select_episode_grid "$id" "$img_path")
        else
            ep_no=$(printf "%s\n" "$ep_list" | select_episode_with_image "$img_path")
        fi
        [ -n "$ANI_DEBUG" ] && printf 'DBG ep_no=[%s]\n' "$ep_no" >&2
        [ -z "$ep_no" ] && exit 1
        ;;
    *)
        if [ "$use_external_menu" = "0" ]; then
            while [ -z "$query" ]; do
                printf "\33[2K\r\033[1;36mBuscar anime: \033[0m" && read -r query
            done
        else
            [ -z "$query" ] && query=$(printf "" | external_menu "" "Buscar anime: " "$external_menu_args")
            [ -z "$query" ] && exit 1
        fi
        # for checking new releases by specifying anime name
        [ "$search" = "nextep" ] && time_until_next_ep "$query"

        query=$(printf "%s" "$query" | sed "s| |+|g")
        anime_list=$(search_anime "$query")
        [ -z "$anime_list" ] && die "No se encontraron resultados"
        [ "$index" -eq "$index" ] 2>/dev/null && result=$(printf "%s" "$anime_list" | sed -n "${index}p")
        if [ -z "$index" ]; then
            anime_menu="$(printf "%s\n" "$anime_list" | awk -F '\t' '{ label = ($3 != "" ? $3 : $2); printf "%d\t%s\t%s\n", NR, $1, label }')"
            result="$(printf "%s" "$anime_menu" | nth "Selecciona anime: ")"
        fi
        [ -z "$result" ] && exit 1
        id=$(printf "%s" "$result" | cut -f1)
        title=$(printf "%s\n" "$anime_list" | awk -F '\t' -v target="$id" '$1 == target { print $2; exit }')
        [ -z "$title" ] && title="$(printf "%s" "$result" | cut -f2)"
        allanime_title="$(printf "%s" "$title" | cut -d'(' -f1 | tr -d '[:punct:]')"
        ep_list=$(episodes_list "$id" "$title")
        [ -z "$ep_no" ] && ep_no=$(printf "%s" "$ep_list" | select_episode)
        [ -z "$ep_no" ] && exit 1
        ;;
esac
[ "$skip_intro" = 1 ] && mal_id="$(ani-skip -q "${skip_title:-${title}}")"

# moves the cursor up one line and clears that line
tput cuu1 && tput el
# stores the position of cursor
tput sc

# playback & loop
if [ "$continuous_mode" = "1" ]; then
    set_continuous_mode 1
fi
play
[ "$player_function" = "download" ] || [ "$player_function" = "debug" ] && exit 0
start_continuous_worker_for_current_player

while cmd=$(playback_menu_options | nth "$(playback_menu_prompt) "); do
    sync_current_episode
    case "$cmd" in
        siguiente)
            prepare_for_menu_playback
            ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{n;p;}") 2>/dev/null
            ;;
        repetir | repetir_episodio_actual)
            prepare_for_menu_playback
            unset episode
            ;;
        anterior)
            prepare_for_menu_playback
            ep_no=$(printf "%s" "$ep_list" | sed -n "/^${ep_no}$/{g;1!p;};h") 2>/dev/null
            ;;
        elegir | elegir_episodio)
            prepare_for_menu_playback
            ep_no=$(printf "%s" "$ep_list" | select_episode)
            ;;
        cambiar_calidad)
            prepare_for_menu_playback
            unset episode
            get_episode_url
            current_site="$selected_site"
            current_quality="$selected_quality"
            site_choice=""
            site_entries="$(available_site_entries "$animeflv_links" "$jkanime_links" "$animeav1_links")"
            site_count="$(printf '%s\n' "$site_entries" | sed '/^$/d' | wc -l | tr -d '[:space:]')"
            if [ "$site_count" -gt 1 ]; then
                site_choice="$(printf "%s\n" "$site_entries" | nth "Selecciona fuente: " | cut -f1)"
                [ -z "$site_choice" ] && continue
                [ "$site_choice" != "$current_site" ] && set_links_for_site "$site_choice"
            fi
            quality_entries="$(quality_menu_entries "$links")"
            quality_count="$(count_quality_links "$links")"
            if [ "$quality_count" -le 1 ]; then
                if [ -n "$site_choice" ] && [ "$site_choice" != "$current_site" ]; then
                    select_quality best
                else
                    printf "Solo hay una calidad disponible para esta fuente\n" 1>&2
                    continue
                fi
            else
                new_quality="$(printf "%s\n" "$quality_entries" | nth "Selecciona calidad: " | cut -f1)"
                [ -z "$new_quality" ] && continue
                [ "${site_choice:-$current_site}" = "$current_site" ] && [ "$new_quality" = "$current_quality" ] && continue
                select_quality "$new_quality"
            fi
            ;;
        modo_continuo_on | modo_continuo_off | modo_continuo_desactivado_activar | modo_continuo_activado_desactivar | activar_modo_continuo | desactivar_modo_continuo)
            toggle_continuous_mode_from_menu
            continue
            ;;
        activar_cerrar_reproductor_anterior | desactivar_cerrar_reproductor_anterior)
            toggle_close_previous_from_menu
            continue
            ;;
        *) exit 0 ;;
    esac
    [ -z "$ep_no" ] && die "Fuera de rango"
    play
    start_continuous_worker_for_current_player
done

