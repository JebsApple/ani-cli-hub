is_spanish_source() {
    case "$1" in
        jkanime | animeav1) return 0 ;;
        *) return 1 ;;
    esac
}

seed_fast_mode_source() {
    [ "$fast_mode" = "1" ] || return 0
    [ -n "$fast_mode_source" ] && return 0

    selected_fast_source="$(site_name_from_ref "$id" 2>/dev/null || true)"
    if ! is_spanish_source "$selected_fast_source" && is_spanish_source "$preferred_info_source"; then
        selected_fast_source="$preferred_info_source"
    fi
    is_spanish_source "$selected_fast_source" || return 0

    fast_mode_source="$selected_fast_source"
    preferred_spanish_site="$(info_source_label "$fast_mode_source")"
    fast_mode_ep_list="$(episodes_list_for_source "$fast_mode_source" "$id" "$title")"
    [ -n "$fast_mode_ep_list" ] && ep_list="$fast_mode_ep_list"
}

source_is_disabled() {
    case " $disabled_spanish_sources " in
        *" $1 "*) return 0 ;;
        *) return 1 ;;
    esac
}

disable_spanish_source() {
    [ -n "$1" ] || return 0
    source_is_disabled "$1" && return 0
    disabled_spanish_sources="${disabled_spanish_sources}${disabled_spanish_sources:+ }$1"
    if [ "$fast_mode_source" = "$1" ]; then
        fast_mode_source=""
        fast_mode_ep_list=""
        ep_list="$(episodes_list "$id" "$title")"
    fi
    printf "Fast mode: desactivando %s para esta sesion.\n" "$(info_source_label "$1")" 1>&2
}

normalize_mirror_name() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's|[[:space:]]\+|_|g'
}

source_mirror_is_disabled_in_list() {
    mirror_key="$(normalize_mirror_name "$2")"
    printf '%s\n' "$3" | grep -Fxq "$1>${mirror_key}"
}

disabled_source_mirrors_for_source() {
    [ -n "$fast_mode_mirror_file" ] && [ -f "$fast_mode_mirror_file" ] || return 0
    grep -E "^$1>" "$fast_mode_mirror_file" 2>/dev/null || true
}

disable_source_mirror() {
    [ "$fast_mode" = "1" ] || return 0
    [ "$fast_mode_source" = "$1" ] || return 0
    [ -n "$2" ] || return 0
    mirror_key="$(normalize_mirror_name "$2")"
    [ -n "$mirror_key" ] || return 0
    [ -n "$fast_mode_mirror_file" ] || return 0
    mirror_entry="$1>${mirror_key}"
    [ -f "$fast_mode_mirror_file" ] && grep -Fxq "$mirror_entry" "$fast_mode_mirror_file" && return 0
    printf '%s\n' "$mirror_entry" >>"$fast_mode_mirror_file"
}

