describe_link_origin() {
    if [ -n "$1" ] && [ -n "$2" ]; then
        [ "$1" = "$2" ] && printf '%s' "$1" || printf '%s / %s' "$1" "$2"
        return 0
    fi
    [ -n "$1" ] && printf '%s' "$1" && return 0
    [ -n "$2" ] && printf '%s' "$2" && return 0
    return 1
}

count_quality_links() {
    printf '%s\n' "$1" | grep -cE '^[0-9]{3,4} >'
}

find_link_quality() {
    printf '%s\n' "$1" | awk -F'>' -v ep="$2" '$1 ~ /^[0-9]{3,4} / && $2==ep { sub(/[[:space:]]+$/, "", $1); print $1; exit }'
}

emit_annotated_link_entry() {
    entry_url="$(printf '%s' "$1" | cut -d'>' -f2)"
    [ -z "$entry_url" ] && entry_url="$1"
    printf '%s\n' "$1"
    [ -n "$2" ] && printf 'source >%s>%s\n' "$entry_url" "$2"
    [ -n "$3" ] && printf 'site >%s>%s\n' "$entry_url" "$3"
}

quality_menu_entries() {
    old_ifs=$IFS
    IFS='
'
    menu_index=1
    for entry in $1; do
        printf '%s' "$entry" | grep -qE '^[0-9]{3,4} >' || continue
        candidate_quality="$(printf '%s' "$entry" | cut -d'>' -f1)"
        candidate_url="$(printf '%s' "$entry" | cut -d'>' -f2)"
        candidate_site="$(find_link_site "$1" "$candidate_url")"
        candidate_source="$(find_link_source "$1" "$candidate_url")"
        origin_label="$(describe_link_origin "$candidate_site" "$candidate_source")"
        [ -n "$origin_label" ] && printf '%s\t%s\t%s\n' "$menu_index" "$candidate_quality" "$origin_label" ||
            printf '%s\t%s\t%s\n' "$menu_index" "$candidate_quality" "Desconocida"
        menu_index=$((menu_index + 1))
    done
    IFS=$old_ifs
}

available_site_entries() {
    menu_index=1
    for site_name in JKAnime AnimeAV1; do
        case "$site_name" in
            JKAnime) site_links="$2" ;;
            AnimeAV1) site_links="$3" ;;
        esac
        site_count="$(count_quality_links "$site_links")"
        [ "$site_count" -gt 0 ] || continue
        printf '%s\t%s\t%s (%s enlaces)\n' "$menu_index" "$site_name" "$site_name" "$site_count"
        menu_index=$((menu_index + 1))
    done
}

set_links_for_site() {
    site_key="$(source_key_from_label "$1" 2>/dev/null || true)"
    case "$1" in
        JKAnime) links="$jkanime_links" ;;
        AnimeAV1) links="$animeav1_links" ;;
        *) return 1 ;;
    esac
    selected_spanish_site="$1"
    preferred_spanish_site="$1"
    if [ "$fast_mode" = "1" ]; then
        if source_is_disabled "$site_key"; then
            disable_spanish_source "$site_key"
        else
            fast_mode_source="$site_key"
            fast_mode_ep_list="$(episodes_list_for_source "$fast_mode_source" "$id" "$title")"
            [ -n "$fast_mode_ep_list" ] && ep_list="$fast_mode_ep_list"
        fi
    fi
    return 0
}

pick_spanish_source_links() {
    site_options="$(available_site_entries "$1" "$2" "$3")"
    available_sites="$(printf '%s\n' "$site_options" | sed '/^$/d')"
    [ -z "$available_sites" ] && return 1

    if [ -n "$preferred_spanish_site" ] && printf '%s\n' "$available_sites" | cut -f2 | grep -Fxq "$preferred_spanish_site"; then
        selected_spanish_site="$preferred_spanish_site"
    else
        site_count="$(printf '%s\n' "$available_sites" | wc -l | tr -d '[:space:]')"
        if [ "$site_count" -eq 1 ]; then
            selected_spanish_site="$(printf '%s\n' "$available_sites" | cut -f2)"
        else
            selected_spanish_site="$(printf '%s\n' "$available_sites" | nth "Selecciona fuente: " | cut -f1)"
        fi
    fi

    case "$selected_spanish_site" in
        JKAnime) set_links_for_site "JKAnime" ;;
        AnimeAV1) set_links_for_site "AnimeAV1" ;;
        *) return 1 ;;
    esac
    return 0
}

link_is_probably_broken() {
    case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
        *novideo* | *no-video* | *no_video* | *video_not_found* | *404.mp4* | *404.m3u8*) return 0 ;;
        *) return 1 ;;
    esac
}

select_ytdlp_url() {
    old_ifs=$IFS
    IFS='
'
    for candidate_url in $1; do
        [ -z "$candidate_url" ] && continue
        printf '%s' "$candidate_url" | grep -qE '^https?://' || continue
        link_is_probably_broken "$candidate_url" && continue
        printf '%s\n' "$candidate_url"
        IFS=$old_ifs
        return 0
    done
    IFS=$old_ifs
    return 1
}

probe_link_with_mpv() {
    probe_referrer=""
    [ -n "$2" ] && probe_referrer="--referrer=$2"

    # Probe candidates with a silent one-frame decode, so only actually playable
    # sources survive selection.
    case "$player_function" in
        flatpak_mpv)
            timeout "${probe_timeout}s" flatpak run io.mpv.Mpv --no-config --ao=null --vo=null --frames=1 \
                --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            ;;
        mpv.exe | */mpv.exe)
            timeout "${probe_timeout}s" "$player_function" --no-config --ao=null --vo=null --frames=1 \
                --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            ;;
        mpv | */mpv)
            timeout "${probe_timeout}s" "$player_function" --no-config --ao=null --vo=null --frames=1 \
                --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            ;;
        *)
            if command -v mpv >/dev/null 2>&1; then
                timeout "${probe_timeout}s" mpv --no-config --ao=null --vo=null --frames=1 \
                    --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            elif command -v flatpak >/dev/null 2>&1 && flatpak info io.mpv.Mpv >/dev/null 2>&1; then
                timeout "${probe_timeout}s" flatpak run io.mpv.Mpv --no-config --ao=null --vo=null --frames=1 \
                    --really-quiet $probe_referrer "$1" >/dev/null 2>&1
            else
                return 0
            fi
            ;;
    esac
}

filter_playable_links() {
    stop_after_first="${2:-}"
    playable_links=""
    old_ifs=$IFS
    IFS='
'
    for entry in $1; do
        printf '%s' "$entry" | grep -qE '^[0-9]{3,4} >' || continue
        candidate_url="$(printf '%s' "$entry" | cut -d'>' -f2)"
        link_is_probably_broken "$candidate_url" && continue
        candidate_referrer="$(find_link_referrer "$1" "$candidate_url")"
        if probe_link_with_mpv "$candidate_url" "$candidate_referrer"; then
            playable_links="${playable_links}${entry}
"
            [ -n "$candidate_referrer" ] && playable_links="${playable_links}referrer >${candidate_url}>${candidate_referrer}
"
            candidate_source="$(find_link_source "$1" "$candidate_url")"
            [ -n "$candidate_source" ] && playable_links="${playable_links}source >${candidate_url}>${candidate_source}
"
            candidate_site="$(find_link_site "$1" "$candidate_url")"
            [ -n "$candidate_site" ] && playable_links="${playable_links}site >${candidate_url}>${candidate_site}
"
            if [ "$stop_after_first" = "first" ]; then
                IFS=$old_ifs
                printf '%s' "$playable_links"
                return 0
            fi
        fi
    done
    IFS=$old_ifs

    [ -n "$playable_links" ] && printf '%s' "$playable_links"
}

extract_streamtape_link() {
    streamtape_page="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s "$1" -A "$agent")" || return 1
    js_expr="$(printf '%s' "$streamtape_page" | tr '\n' ' ' |
        sed -nE "s|.*document.getElementById\\('botlink'\\)\\.innerHTML = ([^;]+);.*|\\1|p" | head -n1)"
    if [ -n "$js_expr" ]; then
        prefix="$(printf '%s' "$js_expr" | sed -nE "s|^[[:space:]]*'([^']*)'.*|\\1|p")"
        suffix="$(printf '%s' "$js_expr" | sed -nE "s|.*\\('([^']*)'\\).*|\\1|p")"
        substring_steps="$(printf '%s' "$js_expr" | grep -oE 'substring\([0-9]+\)' | sed 's/[^0-9]//g')"
        for skip_chars in $substring_steps; do
            skip_chars=$((skip_chars + 1))
            suffix="$(printf '%s' "$suffix" | cut -c"${skip_chars}"-)"
        done
        direct_path="${prefix}${suffix}"
        case "$direct_path" in
            //*) direct_path="https:${direct_path}" ;;
            /*) direct_path="https:/${direct_path}" ;;
        esac
        case "$direct_path" in
            *stream=1*) printf '%s\n' "$direct_path" ;;
            *) printf '%s&stream=1\n' "$direct_path" ;;
        esac
        return 0
    fi

    direct_path="$(printf '%s' "$streamtape_page" | sed -nE 's|.*id="botlink"[^>]*>([^<]+)<.*|\1|p' | tail -n1)"
    [ -z "$direct_path" ] && return 1
    case "$direct_path" in
        //*) direct_path="https:${direct_path}" ;;
        /*) direct_path="https:/${direct_path}" ;;
    esac
    printf '%s&stream=1\n' "$direct_path"
}

extract_hqq_link() {
    hqq_page="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s "$1" -A "$agent")" || return 1
    printf '%s' "$hqq_page" | tr '\n' ' ' |
        sed -nE "s|.*olplayer\\.src\\(\\{[^}]*src: '([^']+)'[^}]*type: 'application/x-mpegURL'.*|\\1|p" | head -n1
}

extract_yourupload_link() {
    direct_link="$(extract_with_ytdlp "$1")"
    [ -n "$direct_link" ] && printf '%s\n' "$direct_link" && return 0

    yourupload_page="$(curl -L --connect-timeout 10 --max-time "$resolver_timeout" -s "$1" -A "$agent")" || return 1
    direct_link="$(printf '%s' "$yourupload_page" | tr '\n' ' ' |
        grep -oE "file:[[:space:]]*'[^']+'" | head -n1 | sed -E "s|file:[[:space:]]*'([^']+)'|\\1|")"
    [ -n "$direct_link" ] && printf '%s\n' "$direct_link" && return 0

    printf '%s' "$yourupload_page" | tr '\n' ' ' |
        grep -oE 'file:[[:space:]]*"[^"]+"' | head -n1 | sed -E 's|file:[[:space:]]*"([^"]+)"|\1|'
}

